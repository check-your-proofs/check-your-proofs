include "zfc_predicate_suc.proof"

definition predicate sucordinal(\alpha) as ordinal(\alpha) \wedge \exists \beta (suc(\beta, \alpha))

definition predicate natural(n) as emptyset(n) \vee (sucordinal(n) \wedge \forall m (in(m, n) \to emptyset(m) \vee sucordinal(m)))

theorem subset_natural_ordinal subset_predicate(natural, ordinal) {
  any n {
    assume natural(n) {
      divide natural(n)
        case emptyset(n) {
          apply invoke emptyset_is_ordinal for n
        }
        case sucordinal(n) \wedge \forall m (in(m, n) \to emptyset(m) \vee sucordinal(m)) {
          split 1 sucordinal(n) \wedge \forall m (in(m, n) \to emptyset(m) \vee sucordinal(m))
          split 1 sucordinal(n)
        }
    }
  }
  fold for subset_predicate conclude subset_predicate(natural, ordinal)
}

theorem emptyset_is_natural \forall n (emptyset(n) \to natural(n)) {
  any n {
    assume emptyset(n) {
      pad emptyset(n) conclude emptyset(n) \vee (sucordinal(n) \wedge \forall m (in(m, n) \to emptyset(m) \vee sucordinal(m)))
      fold for natural conclude natural(n)
    }
  }
}

theorem natural_is_trans trans_predicate(natural) {
  any n, m {
    assume in(m, n) \wedge natural(n) {
      split in(m, n) \wedge natural(n)
      divide natural(n)
        case emptyset(n) {
          apply emptyset(n) for m
          contradict in(m, n)
          explode natural(m)
        }
        case sucordinal(n) \wedge \forall m (in(m, n) \to emptyset(m) \vee sucordinal(m)) {
          split sucordinal(n) \wedge \forall m (in(m, n) \to emptyset(m) \vee sucordinal(m))
          apply invoke \forall m (in(m, n) \to emptyset(m) \vee sucordinal(m)) for m
          divide emptyset(m) \vee sucordinal(m)
            case emptyset(m) {
              apply invoke emptyset_is_natural for m
            }
            case sucordinal(m) {
              any l {
                assume in (l, m) {
                  connect in(l, m) \wedge in(m, n)
                  apply invoke subset_natural_ordinal for n
                  split 1 ordinal(n)
                  apply invoke trans(n) for m, l
                  apply invoke \forall m (in(m, n) \to emptyset(m) \vee sucordinal(m)) for l
                }
              }
              connect sucordinal(m) \wedge \forall l (in(l, m) \to emptyset(l) \vee sucordinal(l))
              pad sucordinal(m) \wedge \forall l (in(l, m) \to emptyset(l) \vee sucordinal(l)) conclude emptyset(m) \vee (sucordinal(m) \wedge \forall l (in(l, m) \to emptyset(l) \vee sucordinal(l)))
              fold for natural conclude natural(m)
            }
        }
    }
  }
  fold for trans_predicate conclude trans_predicate(natural)
}

theorem natural_is_irrefrelon irrefrelon_predicate(natural, in) {
  assert ordinal_is_irrefrelon
  assert subset_natural_ordinal
  connect irrefrelon_predicate(ordinal, in) \wedge subset_predicate(natural, ordinal)
  apply invoke irrefrelon_subset_predicate for ordinal, in, natural
}

theorem natural_is_wellorder wellorder_predicate(natural, in) {
  assert ordinal_is_wellorder
  assert subset_natural_ordinal
  connect wellorder_predicate(ordinal, in) \wedge subset_predicate(natural, ordinal)
  apply invoke wellorder_subset_predicate for ordinal, in, natural
}

theorem natural_is_wellfounded wellfounded_predicate(natural, in) {
  assert natural_is_wellorder
  apply invoke wellorder_implies_wellfounded_predicate for natural, in
}

theorem natural_is_ordinal ordinal_predicate(natural) {
  assert natural_is_trans
  assert natural_is_irrefrelon
  assert natural_is_wellorder
  connect trans_predicate(natural) \wedge irrefrelon_predicate(natural, in) \wedge wellorder_predicate(natural, in)
  fold for ordinal_predicate conclude ordinal_predicate(natural)
}

definition predicate inductive(predicate \phi[1]) as \forall x ((emptyset(x) \to \phi(x)) \wedge (\phi(x) \to \forall y (suc(x, y) \to \phi(y))))

theorem natural_induction \forall^P \phi[1] (inductive(\phi) \to subset_predicate(natural, \phi)) {
  any predicate \phi[1] {
    assume inductive(\phi) {
      deny \neg(subset_predicate(natural, \phi)) {
        apply invoke rightward neg_subset_predicate for natural, \phi
        apply invoke natural_is_wellfounded for \lambda^P n. \neg(\phi(n))
        some n such \exists n (minimal_predicate(natural, in, \lambda^P m. \neg(\phi(m)), n)) {
          split minimal_predicate(natural, in, \lambda^P m. \neg(\phi(m)), n)
          divide natural(n)
            case emptyset(n) {
              apply inductive(\phi) for n
              split 1 (emptyset(n) \to \phi(n)) \wedge (\phi(n) \to \forall m (suc(n, m) \to \phi(m)))
              invoke emptyset(n) \to \phi(n)
              contradict \phi(n)
            }
            case sucordinal(n) \wedge \forall m (in(m, n) \to emptyset(m) \vee sucordinal(m)) {
              split sucordinal(n) \wedge \forall m (in(m, n) \to emptyset(m) \vee sucordinal(m))
              split sucordinal(n)
              some m such \exists m (suc(m, n)) {
                apply invoke suc_implies_in for m, n
                connect in(m, n) \wedge natural(n)
                apply invoke natural_is_trans for n, m
                deny equal(m, n) {
                  substitute in(m, n) for m: n
                  apply invoke natural_is_irrefrelon for n
                  contradict in(n, n)
                }
                deny \neg(\phi(m)) {
                  connect natural(m) \wedge \neg(\phi(m)) \wedge neq(m, n)
                  apply invoke minimal_core_predicate(natural, in, \lambda^P l. \neg(\phi(l)), n) for m
                  contradict in(m, n)
                }
                apply inductive(\phi) for m
                split 2 (emptyset(m) \to \phi(m)) \wedge (\phi(m) \to \forall n (suc(m, n) \to \phi(n)))
                invoke \phi(m) \to \forall n (suc(m, n) \to \phi(n))
                apply invoke \forall n(suc(m, n) \to \phi(n)) for n
                contradict \phi(n)
              }
            }
        }
      }
    }
  }
}
