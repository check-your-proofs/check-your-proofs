include "zfc_powerset.proof"

axiom axiom_schema_of_separation \forall x\forall^T\phi[1]\exists y\forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z))

theorem separation_is_unique \forall x\forall^T\phi[1]\exists!y\forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z)) {
  any x, template \phi[1] {
    apply axiom_schema_of_separation for x:x, \phi:\phi
    some y:y such \exists y\forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z)) {
      any y' {
        assume \forall z(in(z,y')\leftrightarrow in(z,x)\wedge\phi(z)) {
          any z {
            assume in(z,y') {
              apply invoke rightward \forall z(in(z,y')\leftrightarrow in(z,x)\wedge\phi(z)) for z:z
              apply invoke leftward \forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z)) for z:z
            }
            assume in(z,y) {
              apply invoke rightward \forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z)) for z:z
              apply invoke leftward \forall z(in(z,y')\leftrightarrow in(z,x)\wedge\phi(z)) for z:z
            }
            connect in(z,y')\leftrightarrow in(z,y)
          }
          fold for equal conclude equal(y',y)
        }
      }
      connect \forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z))\wedge\forall y'(\forall z(in(z,y')\leftrightarrow in(z,x)\wedge\phi(z))\to equal(y',y))
      characterize for y:y conclude \exists!y\forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z))
    }
  }
}

definition function sep by separation_is_unique
existence sep_existence \forall x\forall^T\phi[1]\forall z(in(z,sep(x,\phi))\leftrightarrow in(z,x)\wedge\phi(z)) by sep
uniqueness sep_uniqueness \forall x\forall^T\phi[1]\forall y(\forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z))\to equal(y,sep(x,\phi))) by sep

theorem sep_cor1 \forall x\forall^T\phi[1](subset(sep(x,\phi),x)) {
  any x, template \phi[1] {
    any z {
      assume in(z,sep(x,\phi)) {
        apply invoke rightward sep_existence for x:x, \phi:\phi, z:z
        split 1 in(z,x)\wedge\phi(z)
      }
    }
    fold for subset conclude subset(sep(x,\phi),x)
  }
}

theorem sep_cor2 \forall x\forall^T\phi[1]\forall z(in(z,sep(x,\phi))\to\phi(z)) {
  any x, template \phi[1], z {
    assume in(z,sep(x,\phi)) {
      apply invoke rightward sep_existence for x:x,\phi:\phi,z:z
      split 2 in(z,x)\wedge\phi(z)
    }
  }
}

definition function bigcap(u) as sep(bigcup(u), lambda z. \forall w(in(w,u)\to in(z,w))) tex "\bigcap",""

theorem bigcap_characterization \forall u\forall z(in(z,bigcap(u))\leftrightarrow in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))) {
  any u, z {
    assume in(z,bigcap(u)) {
      expand in(z,bigcap(u)) for bigcap
      apply invoke rightward sep_existence for x:bigcup(u),\phi: lambda z'. \forall w(in(w,u)\to in(z',w)),z:z
    }
    assume in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w)) {
      apply invoke leftward sep_existence for x:bigcup(u),\phi: lambda z'. \forall w(in(w,u)\to in(z',w)),z:z
      fold for bigcap conclude in(z,bigcap(u))
    }
    connect in(z,bigcap(u))\leftrightarrow in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))
  }
}

theorem bigcap_cor1 equal(bigcap(emptyset),emptyset) {
  apply sep_cor1 for x:bigcup(emptyset), \phi: lambda z. \forall w(in(w,emptyset)\to in(z,w))
  fold for bigcap conclude subset(bigcap(emptyset),bigcup(emptyset))
  assert bigcup_cor2
  substitute subset(bigcap(emptyset),bigcup(emptyset)) for bigcup(emptyset):emptyset
  apply invoke emptyset_subset_cor1 for x:bigcap(emptyset)
}

theorem bigcap_cor2 \forall u(neq(u,emptyset)\to\forall z(in(z,bigcap(u))\leftrightarrow\forall w(in(w,u)\to in(z,w)))) {
  any u {
    assume neq(u,emptyset) {
      any z {
        assume in(z,bigcap(u)) {
          apply invoke rightward bigcap_characterization for u:u,z:z
          split 2 in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))
        }
        assume \forall w(in(w,u)\to in(z,w)) {
          apply invoke not_emptyset_has_a_member for x:u
          some y:y such \exists y(in(y,u)) {
            apply invoke \forall w(in(w,u)\to in(z,w)) for w:y
            connect in(z,y)\wedge in(y,u)
            lift for y:y conclude \exists y(in(z,y)\wedge in(y,u))
          }
          apply invoke leftward bigcup_existence for x:u,z:z
          connect in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))
          apply invoke leftward bigcap_characterization for u:u,z:z
        }
        connect in(z,bigcap(u))\leftrightarrow\forall w(in(w,u)\to in(z,w))
      }
    }
  }
}

theorem bigcap_cor3 \forall x\forall y(in(y,x)\to subset(bigcap(x),y)) {
  any x, y {
    assume in(y,x) {
      any z {
        assume in(z,bigcap(x)) {
          apply invoke rightward bigcap_characterization for z:z,u:x
          split in(z,bigcup(x))\wedge\forall w(in(w,x)\to in(z,w))
          apply invoke \forall w(in(w,x)\to in(z,w)) for w:y
        }
      }
      fold for subset conclude subset(bigcap(x),y)
    }
  }
}

definition function cap(x,y) as bigcap(pair(x,y)) tex "","\cap",""

theorem cap_characterization \forall x\forall y\forall z(in(z,cap(x,y))\leftrightarrow in(z,x)\wedge in(z,y)) {
  any x, y, z {
    apply pair_cor9 for x:x,y:y
    apply invoke bigcap_cor2 for u:pair(x,y)
    assume in(z,cap(x,y)) {
      expand in(z,cap(x,y)) for cap
      apply invoke rightward \forall z(in(z,bigcap(pair(x,y)))\leftrightarrow\forall w(in(w,pair(x,y))\to in(z,w))) for z:z
      apply pair_cor1 for x:x,y:y
      apply invoke \forall w(in(w,pair(x,y))\to in(z,w)) for w:x
      apply pair_cor2 for x:x,y:y
      apply invoke \forall w(in(w,pair(x,y))\to in(z,w)) for w:y
      connect in(z,x)\wedge in(z,y)
    }
    assume in(z,x)\wedge in(z,y) {
      split in(z,x)\wedge in(z,y)
      any w {
        assume in(w,pair(x,y)) {
          apply invoke rightward pair_existence for x:x,y:y,w:w
          divide equal(w,x)\vee equal(w,y)
            case equal(w,x) {
              substitute in(z,x) for x:w
            }
            case equal(w,y) {
              substitute in(z,y) for y:w
            }
        }
      }
      apply invoke leftward \forall z(in(z,bigcap(pair(x,y)))\leftrightarrow\forall w(in(w,pair(x,y))\to in(z,w))) for z:z
      fold for cap conclude in(z,cap(x,y))
    }
    connect in(z,cap(x,y))\leftrightarrow in(z,x)\wedge in(z,y)
  }
}

theorem cap_commutatvity \forall x\forall y(equal(cap(x,y),cap(y,x))) {
  any x,y {
    any z {
      assume in(z,cap(x,y)) {
        apply invoke rightward cap_characterization for x:x,y:y,z:z
        apply invoke leftward cap_characterization for x:y,y:x,z:z
      }
      assume in(z,cap(y,x)) {
        apply invoke rightward cap_characterization for x:y,y:x,z:z
        apply invoke leftward cap_characterization for x:x,y:y,z:z
      }
      connect in(z,cap(x,y))\leftrightarrow in(z,cap(y,x))
    }
    fold for equal conclude equal(cap(x,y),cap(y,x))
  }
}

theorem cap_is_subset_left \forall x\forall y(subset(cap(x,y),x)) {
  any x,y {
    any z {
      assume in(z,cap(x,y)) {
        apply invoke rightward cap_characterization for x:x,y:y,z:z
        split 1 in(z,x)\wedge in(z,y)
      }
    }
    fold for subset conclude subset(cap(x,y),x)
  }
}

theorem cap_is_subset_right \forall x\forall y(subset(cap(x,y),y)) {
  any x,y {
    any z {
      assume in(z,cap(x,y)) {
        apply invoke rightward cap_characterization for x:x,y:y,z:z
        split 2 in(z,x)\wedge in(z,y)
      }
    }
    fold for subset conclude subset(cap(x,y),y)
  }
}

theorem cap_iff_subset \forall x\forall y(equal(cap(x,y),x)\leftrightarrow subset(x,y)) {
  any x,y {
    assume equal(cap(x,y),x) {
      any z {
        assume in(z,x) {
          substitute in(z,x) for x:cap(x,y)
          apply invoke rightward cap_characterization for x:x,y:y,z:z
          split 2 in(z,x)\wedge in(z,y)
        }
      }
      fold for subset conclude subset(x,y)
    }
    assume subset(x,y) {
      any z {
        assume in(z,cap(x,y)) {
          apply invoke rightward cap_characterization for x:x,y:y,z:z
          split 1 in(z,x)\wedge in(z,y)
        }
        assume in(z,x) {
          connect in(z,x)\wedge subset(x,y)
          apply invoke subset_cor1 for z:z,x:x,y:y
          connect in(z,x)\wedge in(z,y)
          apply invoke leftward cap_characterization for x:x,y:y,z:z
        }
        connect in(z,cap(x,y))\leftrightarrow in(z,x)
      }
      fold for equal conclude equal(cap(x,y),x)
    }
    connect equal(cap(x,y),x)\leftrightarrow subset(x,y)
  }
}

theorem neq_cap_iff_neg_subset \forall x\forall y(neq(cap(x,y),x)\leftrightarrow\neg(subset(x,y))) {
  any x,y {
    apply cap_iff_subset for x:x,y:y
    apply invoke neg_iff for \phi:lambda.equal(cap(x,y),x),\psi:lambda.subset(x,y)
  }
}

theorem cap_subsetneq_iff_neq_cap \forall x\forall y(subsetneq(cap(x,y),x)\leftrightarrow neq(cap(x,y),x)) {
  any x,y {
    assume subsetneq(cap(x,y),x) {
      expand subsetneq(cap(x,y),x) for subsetneq
      split 2 subset(cap(x,y),x)\wedge neq(cap(x,y),x)
    }
    assume neq(cap(x,y),x) {
      apply cap_is_subset_left for x:x,y:y
      connect subset(cap(x,y),x)\wedge neq(cap(x,y),x)
      fold for subsetneq conclude subsetneq(cap(x,y),x)
    }
    connect subsetneq(cap(x,y),x)\leftrightarrow neq(cap(x,y),x)
  }
}

theorem cap_subsetneq_iff_neg_subset \forall x\forall y(subsetneq(cap(x,y),x)\leftrightarrow\neg(subset(x,y))) {
  any x,y {
    assume subsetneq(cap(x,y),x) {
      apply invoke rightward cap_subsetneq_iff_neq_cap for x:x,y:y
      apply invoke rightward neq_cap_iff_neg_subset for x:x,y:y
    }
    assume \neg(subset(x,y)) {
      apply invoke leftward neq_cap_iff_neg_subset for x:x,y:y
      apply invoke leftward cap_subsetneq_iff_neq_cap for x:x,y:y
    }
    connect subsetneq(cap(x,y),x)\leftrightarrow\neg(subset(x,y))
  }
}

definition function setminus(x,y) as sep(x,lambda z.notin(z,y)) tex "","\setminus",""

theorem setminus_characterization \forall x\forall y\forall z(in(z,setminus(x,y))\leftrightarrow in(z,x)\wedge notin(z,y)) {
  any x,y,z {
    assume in(z,setminus(x,y)) {
      expand in(z,setminus(x,y)) for setminus
      apply invoke rightward sep_existence for x:x,\phi:lambda z.notin(z,y),z:z
    }
    assume in(z,x)\wedge notin(z,y) {
      apply invoke leftward sep_existence for x:x,\phi:lambda z.notin(z,y),z:z
      fold for setminus conclude in(z,setminus(x,y))
    }
    connect in(z,setminus(x,y))\leftrightarrow in(z,x)\wedge notin(z,y)
  }
}

theorem setminus_is_subset \forall x\forall y(subset(setminus(x,y),x)) {
  any x,y {
    any z {
      assume in(z,setminus(x,y)) {
        apply invoke rightward setminus_characterization for x:x,y:y,z:z
        split 1 in(z,x)\wedge notin(z,y)
      }
    }
    fold for subset conclude subset(setminus(x,y),x)
  }
}

theorem setminus_of_set_and_subsetneq \forall x\forall y(subsetneq(y,x)\to neq(setminus(x,y),emptyset)) {
  any x,y {
    assume subsetneq(y,x) {
      expand subsetneq(y,x) for subsetneq
      split subset(y,x)\wedge neq(y,x)
      deny \forall z(in(z,x)\to in(z,y)) {
        fold for subset conclude subset(x,y)
        connect subset(x,y)\wedge subset(y,x)
        apply invoke rightward subset_antisymmetry for x:x,y:y
        contradict equal(x,y)
      }
      apply invoke leftward exist_neg_leftrightarrow_neg_forall for \phi:lambda z.in(z,x)\to in(z,y)
      some z:z such \exists z(\neg(in(z,x)\to in(z,y))) {
        apply invoke rightward neg_implication for \phi:lambda.in(z,x),\psi:lambda.in(z,y)
        apply invoke leftward setminus_characterization for x:x,y:y,z:z
        lift for z:z conclude \exists z(in(z,setminus(x,y)))
      }
      apply invoke has_a_member_not_emptyset for x:setminus(x,y)
    }
  }
}

definition function cartprod(X,Y) as sep(powerset(powerset(cup(X,Y))), lambda z. \exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))) tex "","\times",""

theorem cartprod_lem1 \forall X\forall Y\forall x\forall y(in(x,X)\wedge in(y,Y)\to in(op(x,y),powerset(powerset(cup(X,Y))))) {
  any X,Y,x,y {
    assume in(x,X)\wedge in(y,Y) {
      split in(x,X)\wedge in(y,Y)
      apply invoke singleton_cor3 for x:x,y:X
      apply cup_cor3 for x:X,y:Y
      connect subset(singleton(x),X)\wedge subset(X,cup(X,Y))
      apply invoke subset_trans for x:singleton(x),y:X,z:cup(X,Y)
      apply invoke leftward powerset_existence for x:cup(X,Y),z:singleton(x)
      apply invoke cup_cor5 for x:x,y:y,X:X,Y:Y
      apply invoke leftward powerset_existence for x:cup(X,Y),z:pair(x,y)
      connect in(singleton(x),powerset(cup(X,Y)))\wedge in(pair(x,y),powerset(cup(X,Y)))
      apply invoke pair_cor10 for x:singleton(x),y:pair(x,y),z:powerset(cup(X,Y))
      fold for op conclude subset(op(x,y),powerset(cup(X,Y)))
      apply invoke leftward powerset_existence for x:powerset(cup(X,Y)),z:op(x,y)
    }
  }
}

theorem cartprod_characterization \forall X\forall Y\forall z(in(z,cartprod(X,Y))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))) {
  any X,Y,z {
    assume in(z,cartprod(X,Y)) {
      expand in(z,cartprod(X,Y)) for cartprod
      apply invoke rightward sep_existence for x:powerset(powerset(cup(X,Y))),\phi:lambda z'. \exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z',op(x,y))),z:z
      split in(z,powerset(powerset(cup(X,Y))))\wedge\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))
    }
    assume \exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y))) {
      some x:x,y:y such \exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y))) {
        split in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y))
        connect in(x,X)\wedge in(y,Y)
        apply invoke cartprod_lem1 for X:X,Y:Y,x:x,y:y
        substitute in(op(x,y),powerset(powerset(cup(X,Y)))) for op(x,y):z
        connect in(z,powerset(powerset(cup(X,Y))))\wedge\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))
        apply invoke leftward sep_existence for x:powerset(powerset(cup(X,Y))),\phi:lambda z'. \exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z',op(x,y))),z:z
        fold for cartprod conclude in(z,cartprod(X,Y))
      }
    }
    connect in(z,cartprod(X,Y))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))
  }
}

theorem cartprod_cor1 \forall X\forall Y\forall x\forall y(in(x,X)\wedge in(y,Y)\leftrightarrow in(op(x,y),cartprod(X,Y))) {
  any X,Y,x,y {
    assume in(x,X)\wedge in(y,Y) {
      split in(x,X)\wedge in(y,Y)
      connect in(x,X)\wedge in(y,Y)\wedge equal(op(x,y),op(x,y))
      lift for x':x,y':y conclude \exists x'\exists y'(in(x',X)\wedge in(y',Y)\wedge equal(op(x,y),op(x',y')))
      apply invoke leftward cartprod_characterization for X:X,Y:Y,z:op(x,y)
    }
    assume in(op(x,y),cartprod(X,Y)) {
      apply invoke rightward cartprod_characterization for X:X,Y:Y,z:op(x,y)
      some x':x',y':y' such \exists x'\exists y'(in(x',X)\wedge in(y',Y)\wedge equal(op(x,y),op(x',y'))) {
        split in(x',X)\wedge in(y',Y)\wedge equal(op(x,y),op(x',y'))
        apply invoke op_characterization for x:x,y:y,x':x',y':y'
        split equal(x,x')\wedge equal(y,y')
        substitute in(x',X) for x':x
        substitute in(y',Y) for y':y
        connect in(x,X)\wedge in(y,Y)
      }
    }
    connect in(x,X)\wedge in(y,Y)\leftrightarrow in(op(x,y),cartprod(X,Y))
  }
}

theorem cartprod_cor2 \forall X(equal(cartprod(X,emptyset),emptyset)) {
  any X {
    any z {
      deny in(z,cartprod(X,emptyset)) {
        apply invoke rightward cartprod_characterization for X:X,Y:emptyset,z:z
        some x:x,y:y such \exists x\exists y(in(x,X)\wedge in(y,emptyset)\wedge equal(z,op(x,y))) {
          split 2 in(x,X)\wedge in(y,emptyset)\wedge equal(z,op(x,y))
          apply emptyset_existence for y:y
          contradict in(y,emptyset)
        }
      }
    }
    apply invoke emptyset_uniqueness for x:cartprod(X,emptyset)
  }
}

theorem cartprod_cor3 \forall Y(equal(cartprod(emptyset,Y),emptyset)) {
  any Y {
    any z {
      deny in(z,cartprod(emptyset,Y)) {
        apply invoke rightward cartprod_characterization for X:emptyset,Y:Y,z:z
        some x:x,y:y such \exists x\exists y(in(x,emptyset)\wedge in(y,Y)\wedge equal(z,op(x,y))) {
          split 1 in(x,emptyset)\wedge in(y,Y)\wedge equal(z,op(x,y))
          apply emptyset_existence for y:x
          contradict in(x,emptyset)
        }
      }
    }
    apply invoke emptyset_uniqueness for x:cartprod(emptyset,Y)
  }
}

theorem cartprod_cor4 \forall X\forall Y(neq(X,emptyset)\wedge neq(Y,emptyset)\to neq(cartprod(X,Y),emptyset)) {
  any X,Y {
    assume neq(X,emptyset)\wedge neq(Y,emptyset) {
      split neq(X,emptyset)\wedge neq(Y,emptyset)
      apply invoke not_emptyset_has_a_member for x:X
      apply invoke not_emptyset_has_a_member for x:Y
      some x:x such \exists x(in(x,X)) {
        some y:y such \exists y(in(y,Y)) {
          connect in(x,X)\wedge in(y,Y)
          apply invoke rightward cartprod_cor1 for X:X,Y:Y,x:x,y:y
          lift for z:op(x,y) conclude \exists z(in(z,cartprod(X,Y)))
        }
      }
      apply invoke has_a_member_not_emptyset for x:cartprod(X,Y)
    }
  }
}
