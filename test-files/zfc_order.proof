include "zfc_relation.proof"

definition predicate transrel(R) as \forall x\forall y\forall z(in(op(x,y),R)\wedge in(op(y,z),R)\to in(op(x,z),R))

definition predicate transrelon(X,R) as relon(X,R)\wedge transrel(R)

definition predicate antisymrel(R) as \forall x\forall y(in(op(x,y),R)\wedge in(op(y,x),R)\to equal(x,y))

definition predicate antisymrelon(X,R) as relon(X,R)\wedge antisymrel(R)

definition predicate order(R) as transrel(R)\wedge antisymrel(R)

definition predicate orderon(X,R) as relon(X,R)\wedge order(R)

definition predicate irrefrel(R) as \forall x(notin(op(x,x),R))

definition predicate irrefrelon(X,R) as relon(X,R)\wedge irrefrel(R)

definition predicate linordon(X,R) as orderon(X,R)\wedge\forall x\forall y(in(x,X)\wedge in(y,X)\to in(op(x,y),R)\vee equal(x,y)\vee in(op(y,x),R))

definition predicate minimal(X,R,A,a) as subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to notin(op(x,a),R))

definition predicate minimum(X,R,A,a) as subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to in(op(a,x),R))

definition predicate wfrelon(X,R) as relon(X,R)\wedge\forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimal(X,R,A,a)))

definition predicate worderon(X,R) as orderon(X,R)\wedge\forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,R,A,a)))

theorem res_of_transrel_is_transrel \forall R\forall X(transrel(R)\to transrel(res(R,X))) {
  any R,X {
    assume transrel(R) {
      expand transrel(R) for transrel
      any x,y,z {
        assume in(op(x,y),res(R,X))\wedge in(op(y,z),res(R,X)) {
          split in(op(x,y),res(R,X))\wedge in(op(y,z),res(R,X))
          apply invoke rightward res_characterization_op for R:R,X:X,x:x,y:y
          split in(op(x,y),R)\wedge in(x,X)\wedge in(y,X)
          apply invoke rightward res_characterization_op for R:R,X:X,x:y,y:z
          split in(op(y,z),R)\wedge in(y,X)\wedge in(z,X)
          connect in(op(x,y),R)\wedge in(op(y,z),R)
          apply invoke \forall x\forall y\forall z(in(op(x,y),R)\wedge in(op(y,z),R)\to in(op(x,z),R)) for x:x,y:y,z:z
          connect in(op(x,z),R)\wedge in(x,X)\wedge in(z,X)
          apply invoke leftward res_characterization_op for R:R,X:X,x:x,y:z
        }
      }
      fold for transrel conclude transrel(res(R,X))
    }
  }
}

theorem res_of_transrelon_is_transrelon \forall R\forall X\forall Y(transrelon(X,R)\wedge subset(Y,X)\to transrelon(Y,res(R,Y))) {
  any X,R,Y {
    assume transrelon(X,R)\wedge subset(Y,X) {
      split transrelon(X,R)\wedge subset(Y,X)
      expand transrelon(X,R) for transrelon
      split relon(X,R)\wedge transrel(R)
      apply res_is_relon for X:Y,R:R
      apply invoke res_of_transrel_is_transrel for R:R,X:Y
      connect relon(Y,res(R,Y))\wedge transrel(res(R,Y))
      fold for transrelon conclude transrelon(Y,res(R,Y))
    }
  }
}

theorem res_of_antisymrel_is_antisymrel \forall R\forall X(antisymrel(R)\to antisymrel(res(R,X))) {
  any R,X {
    assume antisymrel(R) {
      expand antisymrel(R) for antisymrel
      any x,y {
        assume in(op(x,y),res(R,X))\wedge in(op(y,x),res(R,X)) {
          split in(op(x,y),res(R,X))\wedge in(op(y,x),res(R,X))
          apply invoke rightward res_characterization_op for R:R,X:X,x:x,y:y
          split 1 in(op(x,y),R)\wedge in(x,X)\wedge in(y,X)
          apply invoke rightward res_characterization_op for R:R,X:X,x:y,y:x
          split 1 in(op(y,x),R)\wedge in(y,X)\wedge in(x,X)
          connect in(op(x,y),R)\wedge in(op(y,x),R)
          apply invoke \forall x\forall y(in(op(x,y),R)\wedge in(op(y,x),R)\to equal(x,y)) for x:x,y:y
        }
      }
      fold for antisymrel conclude antisymrel(res(R,X))
    }
  }
}

theorem res_of_antisymrelon_is_antisymrelon \forall R\forall X\forall Y(antisymrelon(X,R)\wedge subset(Y,X)\to antisymrelon(Y,res(R,Y))) {
  any X,R,Y {
    assume antisymrelon(X,R)\wedge subset(Y,X) {
      split antisymrelon(X,R)\wedge subset(Y,X)
      expand antisymrelon(X,R) for antisymrelon
      split relon(X,R)\wedge antisymrel(R)
      apply res_is_relon for X:Y,R:R
      apply invoke res_of_antisymrel_is_antisymrel for R:R,X:Y
      connect relon(Y,res(R,Y))\wedge antisymrel(res(R,Y))
      fold for antisymrelon conclude antisymrelon(Y,res(R,Y))
    }
  }
}

theorem res_of_order_is_order \forall R\forall X(order(R)\to order(res(R,X))) {
  any R,X {
    assume order(R) {
      expand order(R) for order
      split transrel(R)\wedge antisymrel(R)
      apply invoke res_of_transrel_is_transrel for R:R,X:X
      apply invoke res_of_antisymrel_is_antisymrel for R:R,X:X
      connect transrel(res(R,X))\wedge antisymrel(res(R,X))
      fold for order conclude order(res(R,X))
    }
  }
}

theorem res_of_orderon_is_orderon \forall R\forall X\forall Y(orderon(X,R)\wedge subset(Y,X)\to orderon(Y,res(R,Y))) {
  any X,R,Y {
    assume orderon(X,R)\wedge subset(Y,X) {
      split orderon(X,R)\wedge subset(Y,X)
      expand orderon(X,R) for orderon
      split relon(X,R)\wedge order(R)
      apply res_is_relon for X:Y,R:R
      apply invoke res_of_order_is_order for R:R,X:Y
      connect relon(Y,res(R,Y))\wedge order(res(R,Y))
      fold for orderon conclude orderon(Y,res(R,Y))
    }
  }
}

theorem res_of_irrefrel_is_irrefrel \forall R\forall X(irrefrel(R)\to irrefrel(res(R,X))) {
  any R,X {
    assume irrefrel(R) {
      expand irrefrel(R) for irrefrel
      any x {
        deny in(op(x,x),res(R,X)) {
          apply invoke rightward res_characterization_op for R:R,X:X,x:x,y:x
          split 1 in(op(x,x),R)\wedge in(x,X)\wedge in(x,X)
          apply \forall x(notin(op(x,x),R)) for x:x
          contradict in(op(x,x),R)
        }
      }
      fold for irrefrel conclude irrefrel(res(R,X))
    }
  }
}

theorem res_of_irrefrelon_is_irrefrelon \forall R\forall X\forall Y(irrefrelon(X,R)\wedge subset(Y,X)\to irrefrelon(Y,res(R,Y))) {
  any X,R,Y {
    assume irrefrelon(X,R)\wedge subset(Y,X) {
      split irrefrelon(X,R)\wedge subset(Y,X)
      expand irrefrelon(X,R) for irrefrelon
      split relon(X,R)\wedge irrefrel(R)
      apply res_is_relon for X:Y,R:R
      apply invoke res_of_irrefrel_is_irrefrel for R:R,X:Y
      connect relon(Y,res(R,Y))\wedge irrefrel(res(R,Y))
      fold for irrefrelon conclude irrefrelon(Y,res(R,Y))
    }
  }
}

theorem res_of_worderon_is_worderon \forall R\forall X\forall Y(worderon(X,R)\wedge subset(Y,X)\to worderon(Y,res(R,Y))) {
  any R,X,Y {
    assume worderon(X,R)\wedge subset(Y,X) {
      split worderon(X,R)\wedge subset(Y,X)
      expand worderon(X,R) for worderon
      split orderon(X,R)\wedge\forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,R,A,a)))
      connect orderon(X,R)\wedge subset(Y,X)
      apply invoke res_of_orderon_is_orderon for R:R,X:X,Y:Y
      any A {
        assume subset(A,Y)\wedge neq(A,emptyset) {
          split subset(A,Y)\wedge neq(A,emptyset)
          connect subset(A,Y)\wedge subset(Y,X)
          apply invoke subset_trans for x:A,y:Y,z:X
          connect subset(A,X)\wedge neq(A,emptyset)
          apply invoke \forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,R,A,a))) for A:A
          some a:a such \exists a(minimum(X,R,A,a)) {
            expand minimum(X,R,A,a) for minimum
            split subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to in(op(a,x),R))
            any x {
              assume in(x,A)\wedge neq(x,a) {
                split in(x,A)\wedge neq(x,a)
                apply invoke \forall x(in(x,A)\wedge neq(x,a)\to in(op(a,x),R)) for x:x
                connect in(a,A)\wedge subset(A,Y)
                apply invoke subset_cor1 for z:a,x:A,y:Y
                connect in(x,A)\wedge subset(A,Y)
                apply invoke subset_cor1 for z:x,x:A,y:Y
                connect in(op(a,x),R)\wedge in(a,Y)\wedge in(x,Y)
                apply invoke leftward res_characterization_op for R:R,X:Y,x:a,y:x
              }
            }
            connect subset(A,Y)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to in(op(a,x),res(R,Y)))
            fold for minimum conclude minimum(Y,res(R,Y),A,a)
            lift for a:a conclude \exists a(minimum(Y,res(R,Y),A,a))
          }
        }
      }
      connect orderon(Y,res(R,Y))\wedge\forall A(subset(A,Y)\wedge neq(A,emptyset)\to\exists a(minimum(Y,res(R,Y),A,a)))
      fold for worderon conclude worderon(Y,res(R,Y))
    }
  }
}

theorem transrel_relsep_subset \forall X\forall^T\phi[2]\forall Y(transrel(relsep(X,\phi))\wedge subset(Y,X)\to transrel(relsep(Y,\phi))) {
  any X, template \phi[2], Y {
    assume transrel(relsep(X,\phi))\wedge subset(Y,X) {
      split transrel(relsep(X,\phi))\wedge subset(Y,X)
      apply invoke res_of_transrel_is_transrel for R:relsep(X,\phi),X:Y
      apply invoke relsep_res for X:X,\phi:\phi,Y:Y
      substitute transrel(res(relsep(X,\phi),Y)) for res(relsep(X,\phi),Y):relsep(Y,\phi)
    }
  }
}

theorem transrelon_relsep_subset \forall X\forall^T\phi[2]\forall Y(transrelon(X,relsep(X,\phi))\wedge subset(Y,X)\to transrelon(Y,relsep(Y,\phi))) {
  any X, template \phi[2], Y {
    assume transrelon(X,relsep(X,\phi))\wedge subset(Y,X) {
      split transrelon(X,relsep(X,\phi))\wedge subset(Y,X)
      apply invoke res_of_transrelon_is_transrelon for R:relsep(X,\phi),X:X,Y:Y
      apply invoke relsep_res for X:X,\phi:\phi,Y:Y
      substitute transrelon(Y,res(relsep(X,\phi),Y)) for res(relsep(X,\phi),Y):relsep(Y,\phi)
    }
  }
}

theorem antisymrel_relsep_subset \forall X\forall^T\phi[2]\forall Y(antisymrel(relsep(X,\phi))\wedge subset(Y,X)\to antisymrel(relsep(Y,\phi))) {
  any X, template \phi[2], Y {
    assume antisymrel(relsep(X,\phi))\wedge subset(Y,X) {
      split antisymrel(relsep(X,\phi))\wedge subset(Y,X)
      apply invoke res_of_antisymrel_is_antisymrel for R:relsep(X,\phi),X:Y
      apply invoke relsep_res for X:X,\phi:\phi,Y:Y
      substitute antisymrel(res(relsep(X,\phi),Y)) for res(relsep(X,\phi),Y):relsep(Y,\phi)
    }
  }
}

theorem antisymrelon_relsep_subset \forall X\forall^T\phi[2]\forall Y(antisymrelon(X,relsep(X,\phi))\wedge subset(Y,X)\to antisymrelon(Y,relsep(Y,\phi))) {
  any X, template \phi[2], Y {
    assume antisymrelon(X,relsep(X,\phi))\wedge subset(Y,X) {
      split antisymrelon(X,relsep(X,\phi))\wedge subset(Y,X)
      apply invoke res_of_antisymrelon_is_antisymrelon for R:relsep(X,\phi),X:X,Y:Y
      apply invoke relsep_res for X:X,\phi:\phi,Y:Y
      substitute antisymrelon(Y,res(relsep(X,\phi),Y)) for res(relsep(X,\phi),Y):relsep(Y,\phi)
    }
  }
}

theorem order_relsep_subset \forall X\forall^T\phi[2]\forall Y(order(relsep(X,\phi))\wedge subset(Y,X)\to order(relsep(Y,\phi))) {
  any X, template \phi[2], Y {
    assume order(relsep(X,\phi))\wedge subset(Y,X) {
      split order(relsep(X,\phi))\wedge subset(Y,X)
      expand order(relsep(X,\phi)) for order
      split transrel(relsep(X,\phi))\wedge antisymrel(relsep(X,\phi))
      connect transrel(relsep(X,\phi))\wedge subset(Y,X)
      apply invoke transrel_relsep_subset for X:X,\phi:\phi,Y:Y
      connect antisymrel(relsep(X,\phi))\wedge subset(Y,X)
      apply invoke antisymrel_relsep_subset for X:X,\phi:\phi,Y:Y
      connect transrel(relsep(Y,\phi))\wedge  antisymrel(relsep(Y,\phi))
      fold for order conclude order(relsep(Y,\phi))
    }
  }
}

theorem orderon_relsep_subset \forall X\forall^T\phi[2]\forall Y(orderon(X,relsep(X,\phi))\wedge subset(Y,X)\to orderon(Y,relsep(Y,\phi))) {
  any X, template \phi[2], Y {
    assume orderon(X,relsep(X,\phi))\wedge subset(Y,X) {
      split orderon(X,relsep(X,\phi))\wedge subset(Y,X)
      apply invoke res_of_orderon_is_orderon for R:relsep(X,\phi),X:X,Y:Y
      apply invoke relsep_res for X:X,\phi:\phi,Y:Y
      substitute orderon(Y,res(relsep(X,\phi),Y)) for res(relsep(X,\phi),Y):relsep(Y,\phi)
    }
  }
}

theorem irrefrel_relsep_subset \forall X\forall^T\phi[2]\forall Y(irrefrel(relsep(X,\phi))\wedge subset(Y,X)\to irrefrel(relsep(Y,\phi))) {
  any X, template \phi[2], Y {
    assume irrefrel(relsep(X,\phi))\wedge subset(Y,X) {
      split irrefrel(relsep(X,\phi))\wedge subset(Y,X)
      apply invoke res_of_irrefrel_is_irrefrel for R:relsep(X,\phi),X:Y
      apply invoke relsep_res for X:X,\phi:\phi,Y:Y
      substitute irrefrel(res(relsep(X,\phi),Y)) for res(relsep(X,\phi),Y):relsep(Y,\phi)
    }
  }
}

theorem irrefrelon_relsep_subset \forall X\forall^T\phi[2]\forall Y(irrefrelon(X,relsep(X,\phi))\wedge subset(Y,X)\to irrefrelon(Y,relsep(Y,\phi))) {
  any X, template \phi[2], Y {
    assume irrefrelon(X,relsep(X,\phi))\wedge subset(Y,X) {
      split irrefrelon(X,relsep(X,\phi))\wedge subset(Y,X)
      apply invoke res_of_irrefrelon_is_irrefrelon for R:relsep(X,\phi),X:X,Y:Y
      apply invoke relsep_res for X:X,\phi:\phi,Y:Y
      substitute irrefrelon(Y,res(relsep(X,\phi),Y)) for res(relsep(X,\phi),Y):relsep(Y,\phi)
    }
  }
}

theorem worderon_relsep_subset \forall X\forall^T\phi[2]\forall Y(worderon(X,relsep(X,\phi))\wedge subset(Y,X)\to worderon(Y,relsep(Y,\phi))) {
  any X, template \phi[2], Y {
    assume worderon(X,relsep(X,\phi))\wedge subset(Y,X) {
      split worderon(X,relsep(X,\phi))\wedge subset(Y,X)
      apply invoke res_of_worderon_is_worderon for R:relsep(X,\phi),X:X,Y:Y
      apply invoke relsep_res for X:X,\phi:\phi,Y:Y
      substitute worderon(Y,res(relsep(X,\phi),Y)) for res(relsep(X,\phi),Y):relsep(Y,\phi)
    }
  }
}

theorem emptyset_is_transrel transrel(emptyset) {
  any x,y,z {
    assume in(op(x,y),emptyset)\wedge in(op(y,z),emptyset) {
      split in(op(x,y),emptyset)\wedge in(op(y,z),emptyset)
      apply emptyset_existence for y:op(x,y)
      contradict in(op(x,y),emptyset)
      explode in(op(x,z),emptyset)
    }
  }
  fold for transrel conclude transrel(emptyset)
}

theorem emptyset_is_transrelon_emptyset transrelon(emptyset,emptyset) {
  assert emptyset_is_relon_emptyset
  assert emptyset_is_transrel
  connect relon(emptyset,emptyset)\wedge transrel(emptyset)
  fold for transrelon conclude transrelon(emptyset,emptyset)
}

theorem emptyset_is_antisymrel antisymrel(emptyset) {
  any x,y {
    assume in(op(x,y),emptyset)\wedge in(op(y,x),emptyset) {
      split 1 in(op(x,y),emptyset)\wedge in(op(y,x),emptyset)
      apply emptyset_existence for y:op(x,y)
      contradict in(op(x,y),emptyset)
      explode equal(x,y)
    }
  }
  fold for antisymrel conclude antisymrel(emptyset)
}

theorem emptyset_is_antisymrelon_emptyset antisymrelon(emptyset,emptyset) {
  assert emptyset_is_relon_emptyset
  assert emptyset_is_antisymrel
  connect relon(emptyset,emptyset)\wedge antisymrel(emptyset)
  fold for antisymrelon conclude antisymrelon(emptyset,emptyset)
}

theorem emptyset_is_order order(emptyset) {
  assert emptyset_is_transrel
  assert emptyset_is_antisymrel
  connect transrel(emptyset)\wedge antisymrel(emptyset)
  fold for order conclude order(emptyset)
}

theorem emptyset_is_orderon_emptyset orderon(emptyset,emptyset) {
  assert emptyset_is_relon_emptyset
  assert emptyset_is_order
  connect relon(emptyset,emptyset)\wedge order(emptyset)
  fold for orderon conclude orderon(emptyset,emptyset)
}

theorem emptyset_is_irrefrel irrefrel(emptyset) {
  any x {
    apply emptyset_existence for y:op(x,x)
  }
  fold for irrefrel conclude irrefrel(emptyset)
}

theorem emptyset_is_irrefrelon_emptyset irrefrelon(emptyset,emptyset) {
  assert emptyset_is_relon_emptyset
  assert emptyset_is_irrefrel
  connect relon(emptyset,emptyset)\wedge irrefrel(emptyset)
  fold for irrefrelon conclude irrefrelon(emptyset,emptyset)
}

theorem emptyset_is_worderon_emptyset worderon(emptyset,emptyset) {
  assert emptyset_is_orderon_emptyset
  any A {
    assume subset(A,emptyset)\wedge neq(A,emptyset) {
      split subset(A,emptyset)\wedge neq(A,emptyset)
      apply invoke emptyset_subset_cor1 for x:A
      contradict equal(A,emptyset)
      explode \exists a(minimum(emptyset,emptyset,A,a))
    }
  }
  connect orderon(emptyset,emptyset)\wedge\forall A(subset(A,emptyset)\wedge neq(A,emptyset)\to\exists a(minimum(emptyset,emptyset,A,a)))
  fold for worderon conclude worderon(emptyset,emptyset)
}

definition predicate trans(x) as \forall y(in(y,x)\to\forall z(in(z,y)\to in(z,x)))

theorem trans_cor1 \forall x(trans(x)\leftrightarrow\forall y(in(y,x)\to subset(y,x))) {
  any x {
    assume trans(x) {
      expand trans(x) for trans
      fold for subset conclude \forall y(in(y,x)\to subset(y,x))
    }
    assume \forall y(in(y,x)\to subset(y,x)) {
      any y {
        assume in(y,x) {
          any z {
            assume in(z,y) {
              apply invoke \forall y(in(y,x)\to subset(y,x)) for y:y
              connect in(z,y)\wedge subset(y,x)
              apply invoke subset_cor1 for z:z,x:y,y:x
            }
          }
        }
      }
      fold for trans conclude trans(x)
    }
    connect trans(x)\leftrightarrow\forall y(in(y,x)\to subset(y,x))
  }
}

theorem emptyset_is_trans trans(emptyset) {
  any x {
    assume in(x,emptyset) {
      apply emptyset_existence for y:x
      contradict in(x,emptyset)
      explode \forall y(in(y,x)\to in(y,emptyset))
    }
  }
  fold for trans conclude trans(emptyset)
}

definition function mem(X) as relsep(X,lambda x,y.in(x,y))

theorem mem_characterization \forall X\forall z(in(z,mem(X))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge in(x,y))) {
  any X,z {
    assume in(z,mem(X)) {
      expand in(z,mem(X)) for mem
      apply invoke rightward relsep_characterization for X:X,\phi:lambda x,y.in(x,y),z:z
    }
    assume \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge in(x,y)) {
      apply invoke leftward relsep_characterization for X:X,\phi:lambda x,y.in(x,y),z:z
      fold for mem conclude in(z,mem(X))
    }
    connect in(z,mem(X))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge in(x,y))
  }
}

theorem mem_cor1 \forall X\forall x\forall y(in(op(x,y),mem(X))\leftrightarrow in(x,X)\wedge in(y,X)\wedge in(x,y)) {
  any X,x,y {
    assume in(op(x,y),mem(X)) {
      apply invoke rightward mem_characterization for X:X,z:op(x,y)
      some x':x',y':y' such \exists x'\exists y'(in(x',X)\wedge in(y',X)\wedge equal(op(x,y),op(x',y'))\wedge in(x',y')) {
        split in(x',X)\wedge in(y',X)\wedge equal(op(x,y),op(x',y'))\wedge in(x',y')
        apply invoke op_characterization for x:x,y:y,x':x',y':y'
        split equal(x,x')\wedge equal(y,y')
        substitute in(x',X) for x':x
        substitute in(y',X) for y':y
        substitute in(x',y') for x':x,y':y
        connect in(x,X)\wedge in(y,X)\wedge in(x,y)
      }
    }
    assume in(x,X)\wedge in(y,X)\wedge in(x,y) {
      split in(x,X)\wedge in(y,X)\wedge in(x,y)
      connect in(x,X)\wedge in(y,X)\wedge equal(op(x,y),op(x,y))\wedge in(x,y)
      lift for x:x,y:y conclude \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(op(x,y),op(x,y))\wedge in(x,y))
      apply invoke leftward mem_characterization for X:X,z:op(x,y)
    }
    connect in(op(x,y),mem(X))\leftrightarrow in(x,X)\wedge in(y,X)\wedge in(x,y)
  }
}

theorem mem_relon \forall X(relon(X,mem(X))) {
  any X {
    apply relsep_relon for X:X,\phi:lambda x,y.in(x,y)
    fold for mem conclude relon(X,mem(X))
  }
}

theorem mem_res \forall X\forall Y(subset(Y,X)\to equal(mem(Y),res(mem(X),Y))) {
  any X,Y {
    assume subset(Y,X) {
      apply invoke relsep_res for X:X,\phi:lambda x,y.in(x,y),Y:Y
      fold for mem conclude equal(mem(Y),res(mem(X),Y))
    }
  }
}

theorem mem_trasnrel_subset \forall X\forall Y(transrel(mem(X))\wedge subset(Y,X)\to transrel(mem(Y))) {
  any X,Y {
    assume transrel(mem(X))\wedge subset(Y,X) {
      split transrel(mem(X))\wedge subset(Y,X)
      expand transrel(mem(X)) for mem
      connect transrel(relsep(X,lambda x,y.in(x,y)))\wedge subset(Y,X)
      apply invoke transrel_relsep_subset for X:X,\phi:lambda x,y.in(x,y),Y:Y
      fold for mem conclude transrel(mem(Y))
    }
  }
}

