include "zfc_relation.proof"

definition predicate relon(X,R) as \forall z(in(z,R)\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))))

theorem emptyset_is_relon_emptyset relon(emptyset,emptyset) {
  any z {
    assume in(z,emptyset) {
      apply emptyset_existence for y:z
      contradict in(z,emptyset)
      explode \exists x\exists y(in(x,emptyset)\wedge in(y,emptyset)\wedge equal(z,op(x,y)))
    }
    assume \exists x\exists y(in(x,emptyset)\wedge in(y,emptyset)\wedge equal(z,op(x,y))) {
      some x:x,y:y such \exists x\exists y(in(x,emptyset)\wedge in(y,emptyset)\wedge equal(z,op(x,y))) {
        split 1 in(x,emptyset)\wedge in(y,emptyset)\wedge equal(z,op(x,y))
        apply emptyset_existence for y:x
        contradict in(x,emptyset)
        explode in(z,emptyset)
      }
    }
    connect in(z,emptyset)\leftrightarrow\exists x\exists y(in(x,emptyset)\wedge in(y,emptyset)\wedge equal(z,op(x,y)))
  }
  fold for relon conclude relon(emptyset,emptyset)
}

definition predicate transrelon(X,R) as relon(X,R)\wedge\forall x\forall y\forall z(in(op(x,y),R)\wedge in(op(y,z),R)\to in(op(x,z),R))

theorem emptyset_is_transrelon_emptyset transrelon(emptyset,emptyset) {
  any x,y,z {
    assume in(op(x,y),emptyset)\wedge in(op(y,z),emptyset) {
      split in(op(x,y),emptyset)\wedge in(op(y,z),emptyset)
      apply emptyset_existence for y:op(x,y)
      contradict in(op(x,y),emptyset)
      explode in(op(x,z),emptyset)
    }
  }
  assert emptyset_is_relon_emptyset
  connect relon(emptyset,emptyset)\wedge\forall x\forall y\forall z(in(op(x,y),emptyset)\wedge in(op(y,z),emptyset)\to in(op(x,z),emptyset))
  fold for transrelon conclude transrelon(emptyset,emptyset)
}

definition predicate antisymrelon(X,R) as relon(X,R)\wedge\forall x\forall y(in(op(x,y),R)\wedge in(op(y,x),R)\to equal(x,y))

theorem emptyset_is_antisymrelon_emptyset antisymrelon(emptyset,emptyset) {
  assert emptyset_is_relon_emptyset
  any x,y {
    assume in(op(x,y),emptyset)\wedge in(op(y,x),emptyset) {
      split in(op(x,y),emptyset)\wedge in(op(y,x),emptyset)
      apply emptyset_existence for y:op(x,y)
      contradict in(op(x,y),emptyset)
      explode equal(x,y)
    }
  }
  connect relon(emptyset,emptyset)\wedge\forall x\forall y(in(op(x,y),emptyset)\wedge in(op(y,x),emptyset)\to equal(x,y))
  fold for antisymrelon conclude antisymrelon(emptyset,emptyset)
}

definition predicate ordon(X,R) as transrelon(X,R)\wedge antisymrelon(X,R)

theorem emptyset_is_ordon_emptyset ordon(emptyset,emptyset) {
  assert emptyset_is_transrelon_emptyset
  assert emptyset_is_antisymrelon_emptyset
  connect transrelon(emptyset,emptyset)\wedge antisymrelon(emptyset,emptyset)
  fold for ordon conclude ordon(emptyset,emptyset)
}

definition predicate irrefrelon(X,R) as relon(X,R)\wedge\forall x(notin(op(x,x),R))

theorem emptyset_is_irrefrelon_on_emptyset irrefrelon(emptyset,emptyset) {
  assert emptyset_is_relon_emptyset
  any x {
    apply emptyset_existence for y:op(x,x)
  }
  connect relon(emptyset,emptyset)\wedge\forall x(notin(op(x,x),emptyset))
  fold for irrefrelon conclude irrefrelon(emptyset,emptyset)
}

definition predicate linordon(X,R) as ordon(X,R)\wedge\forall x\forall y(in(x,X)\wedge in(y,X)\to in(op(x,y),R)\vee equal(x,y)\vee in(op(y,x),R))

definition predicate minimal(X,R,A,a) as subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to notin(op(x,a),R))

definition predicate minimum(X,R,A,a) as subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to in(op(a,x),R))

definition predicate wfrelon(X,R) as relon(X,R)\wedge\forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimal(X,R,A,a)))

definition predicate wordon(X,R) as ordon(X,R)\wedge\forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,R,A,a)))

theorem emptyset_is_wordon_emptyset wordon(emptyset,emptyset) {
  assert emptyset_is_ordon_emptyset
  any A {
    assume subset(A,emptyset)\wedge neq(A,emptyset) {
      split subset(A,emptyset)\wedge neq(A,emptyset)
      apply invoke emptyset_subset_cor1 for x:A
      contradict equal(A,emptyset)
      explode \exists a(minimum(emptyset,emptyset,A,a))
    }
  }
  connect ordon(emptyset,emptyset)\wedge\forall A(subset(A,emptyset)\wedge neq(A,emptyset)\to\exists a(minimum(emptyset,emptyset,A,a)))
  fold for wordon conclude wordon(emptyset,emptyset)
}

definition predicate trans(x) as \forall y(in(y,x)\to\forall z(in(z,y)\to in(z,x)))

theorem trans_cor1 \forall x(trans(x)\leftrightarrow\forall y(in(y,x)\to subset(y,x))) {
  any x {
    assume trans(x) {
      expand trans(x) for trans
      fold for subset conclude \forall y(in(y,x)\to subset(y,x))
    }
    assume \forall y(in(y,x)\to subset(y,x)) {
      any y {
        assume in(y,x) {
          any z {
            assume in(z,y) {
              apply invoke \forall y(in(y,x)\to subset(y,x)) for y:y
              connect in(z,y)\wedge subset(y,x)
              apply invoke subset_cor1 for z:z,x:y,y:x
            }
          }
        }
      }
      fold for trans conclude trans(x)
    }
    connect trans(x)\leftrightarrow\forall y(in(y,x)\to subset(y,x))
  }
}

theorem emptyset_is_trans trans(emptyset) {
  any x {
    assume in(x,emptyset) {
      apply emptyset_existence for y:x
      contradict in(x,emptyset)
      explode \forall y(in(y,x)\to in(y,emptyset))
    }
  }
  fold for trans conclude trans(emptyset)
}

definition function mem(X) as sep(cartprod(X,X),lambda z.\exists x\exists y(equal(z,op(x,y))\wedge in(x,y)))

theorem mem_characterization \forall X\forall z(in(z,mem(X))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge in(x,y))) {
  any X,z {
    assume in(z,mem(X)) {
      expand in(z,mem(X)) for mem
      apply invoke rightward sep_existence for x:cartprod(X,X),\phi:lambda z.\exists x\exists y(equal(z,op(x,y))\wedge in(x,y)),z:z
      split in(z,cartprod(X,X))\wedge\exists x\exists y(equal(z,op(x,y))\wedge in(x,y))
      some x:x,y:y such \exists x\exists y(equal(z,op(x,y))\wedge in(x,y)) {
        split equal(z,op(x,y))\wedge in(x,y)
        substitute in(z,cartprod(X,X)) for z:op(x,y)
        apply invoke leftward cartprod_cor1 for X:X,Y:X,x:x,y:y
        split in(x,X)\wedge in(y,X)
        connect in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge in(x,y)
        lift for x:x,y:y conclude \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge in(x,y))
      }
    }
    assume \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge in(x,y)) {
      some x:x,y:y such \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge in(x,y)) {
        split in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge in(x,y)
        connect in(x,X)\wedge in(y,X)
        apply invoke rightward cartprod_cor1 for X:X,Y:X,x:x,y:y
        substitute in(op(x,y),cartprod(X,X)) for op(x,y):z
        connect equal(z,op(x,y))\wedge in(x,y)
        lift for x:x,y:y conclude \exists x\exists y(equal(z,op(x,y))\wedge in(x,y))
        connect in(z,cartprod(X,X))\wedge\exists x\exists y(equal(z,op(x,y))\wedge in(x,y))
      }
      apply invoke leftward sep_existence for x:cartprod(X,X),\phi:lambda z.\exists x\exists y(equal(z,op(x,y))\wedge in(x,y)),z:z
      fold for mem conclude in(z,mem(X))
    }
    connect in(z,mem(X))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge in(x,y))
  }
}

theorem mem_cor1 \forall X\forall x\forall y(in(op(x,y),mem(X))\leftrightarrow in(x,X)\wedge in(y,X)\wedge in(x,y)) {
  any X,x,y {
    assume in(op(x,y),mem(X)) {
      apply invoke rightward mem_characterization for X:X,z:op(x,y)
      some x':x',y':y' such \exists x'\exists y'(in(x',X)\wedge in(y',X)\wedge equal(op(x,y),op(x',y'))\wedge in(x',y')) {
        split in(x',X)\wedge in(y',X)\wedge equal(op(x,y),op(x',y'))\wedge in(x',y')
        apply invoke op_characterization for x:x,y:y,x':x',y':y'
        split equal(x,x')\wedge equal(y,y')
        substitute in(x',X) for x':x
        substitute in(y',X) for y':y
        substitute in(x',y') for x':x,y':y
        connect in(x,X)\wedge in(y,X)\wedge in(x,y)
      }
    }
    assume in(x,X)\wedge in(y,X)\wedge in(x,y) {
      split in(x,X)\wedge in(y,X)\wedge in(x,y)
      connect in(x,X)\wedge in(y,X)\wedge equal(op(x,y),op(x,y))\wedge in(x,y)
      lift for x:x,y:y conclude \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(op(x,y),op(x,y))\wedge in(x,y))
      apply invoke leftward mem_characterization for X:X,z:op(x,y)
    }
    connect in(op(x,y),mem(X))\leftrightarrow in(x,X)\wedge in(y,X)\wedge in(x,y)
  }
}

theorem mem_of_emptyset_is_emptyset equal(mem(emptyset),emptyset) {
  any z {
    deny in(z,mem(emptyset)) {
      apply invoke rightward mem_characterization for X:emptyset,z:z
      some x:x,y:y such \exists x\exists y(in(x,emptyset)\wedge in(y,emptyset)\wedge equal(z,op(x,y))\wedge in(x,y)) {
        split 1 in(x,emptyset)\wedge in(y,emptyset)\wedge equal(z,op(x,y))\wedge in(x,y)
        apply emptyset_existence for y:x
        contradict in(x,emptyset)
      }
    }
  }
  apply invoke emptyset_uniqueness for x:mem(emptyset)
}

definition predicate ord(\alpha) as trans(\alpha)\wedge irrefrelon(\alpha,mem(\alpha))\wedge wordon(\alpha,mem(\alpha))

theorem emptyset_is_ord ord(emptyset) {
  assert emptyset_is_trans
  assert mem_of_emptyset_is_emptyset
  assert emptyset_is_irrefrelon_on_emptyset
  substitute irrefrelon(emptyset,emptyset) for emptyset[2]:mem(emptyset)
  assert emptyset_is_wordon_emptyset
  substitute wordon(emptyset,emptyset) for emptyset[2]:mem(emptyset)
  connect trans(emptyset)\wedge irrefrelon(emptyset,mem(emptyset))\wedge wordon(emptyset,mem(emptyset))
  fold for ord conclude ord(emptyset)
}

theorem element_of_ordianl_is_trans \forall\alpha(ord(\alpha)\to\forall\beta(in(\beta,\alpha)\to trans(\beta))) {
  any \alpha {
    assume ord(\alpha) {
      any \beta {
        assume in(\beta,\alpha) {
          any \gamma {
            assume in(\gamma,\beta) {
              any \delta {
                assume in(\delta,\gamma) {
                  expand ord(\alpha) for ord
                  split trans(\alpha)\wedge irrefrelon(\alpha,mem(\alpha))\wedge wordon(\alpha,mem(\alpha))
                  expand trans(\alpha) for trans
                  apply invoke \forall y(in(y,\alpha)\to\forall z(in(z,y)\to in(z,\alpha))) for y:\beta
                  apply invoke \forall z(in(z,\beta)\to in(z,\alpha)) for z:\gamma
                  apply invoke \forall y(in(y,\alpha)\to\forall z(in(z,y)\to in(z,\alpha))) for y:\gamma
                  apply invoke \forall z(in(z,\gamma)\to in(z,\alpha)) for z:\delta
                  connect in(\gamma,\alpha)\wedge in(\beta,\alpha)\wedge in(\gamma,\beta)
                  apply invoke leftward mem_cor1 for X:\alpha,x:\gamma,y:\beta
                  connect in(\delta,\alpha)\wedge in(\gamma,\alpha)\wedge in(\delta,\gamma)
                  apply invoke leftward mem_cor1 for X:\alpha,x:\delta,y:\gamma
                  connect in(op(\delta,\gamma),mem(\alpha))\wedge in(op(\gamma,\beta),mem(\alpha))
                  expand wordon(\alpha,mem(\alpha)) for wordon
                  split 1 ordon(\alpha,mem(\alpha))\wedge\forall A(subset(A,\alpha)\wedge neq(A,emptyset)\to\exists a(minimum(\alpha,mem(\alpha),A,a)))
                  expand ordon(\alpha,mem(\alpha)) for ordon
                  split 1 transrelon(\alpha,mem(\alpha))\wedge antisymrelon(\alpha,mem(\alpha))
                  expand transrelon(\alpha,mem(\alpha)) for transrelon
                  split 2 relon(\alpha,mem(\alpha))\wedge\forall x\forall y\forall z(in(op(x,y),mem(\alpha))\wedge in(op(y,z),mem(\alpha))\to in(op(x,z),mem(\alpha)))
                  apply invoke \forall x\forall y\forall z(in(op(x,y),mem(\alpha))\wedge in(op(y,z),mem(\alpha))\to in(op(x,z),mem(\alpha))) for x:\delta,y:\gamma,z:\beta
                  apply invoke rightward mem_cor1 for X:\alpha,x:\delta,y:\beta
                  split 3 in(\delta,\alpha)\wedge in(\beta,\alpha)\wedge in(\delta,\beta)
                }
              }
            }
          }
          fold for trans conclude trans(\beta)
        }
      }
    }
  }
}
