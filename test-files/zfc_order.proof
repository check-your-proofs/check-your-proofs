theorem mem_of_emptyset_is_emptyset equal(mem(emptyset),emptyset) {
  any z {
    deny in(z,mem(emptyset)) {
      apply invoke rightward mem_characterization for X:emptyset,z:z
      some x:x,y:y such \exists x\exists y(in(x,emptyset)\wedge in(y,emptyset)\wedge equal(z,op(x,y))\wedge in(x,y)) {
        split 1 in(x,emptyset)\wedge in(y,emptyset)\wedge equal(z,op(x,y))\wedge in(x,y)
        apply emptyset_existence for y:x
        contradict in(x,emptyset)
      }
    }
  }
  apply invoke emptyset_uniqueness for x:mem(emptyset)
}

definition predicate ordinal(\alpha) as trans(\alpha)\wedge irrefrelon(\alpha,mem(\alpha))\wedge worderon(\alpha,mem(\alpha))

theorem emptyset_is_ordinal ordinal(emptyset) {
  assert emptyset_is_trans
  assert mem_of_emptyset_is_emptyset
  assert emptyset_is_irrefrelon_emptyset
  substitute irrefrelon(emptyset,emptyset) for emptyset[2]:mem(emptyset)
  assert emptyset_is_worderon_emptyset
  substitute worderon(emptyset,emptyset) for emptyset[2]:mem(emptyset)
  connect trans(emptyset)\wedge irrefrelon(emptyset,mem(emptyset))\wedge worderon(emptyset,mem(emptyset))
  fold for ordinal conclude ordinal(emptyset)
}

theorem element_of_ordinal_is_trans \forall\alpha(ordinal(\alpha)\to\forall\beta(in(\beta,\alpha)\to trans(\beta))) {
  any \alpha {
    assume ordinal(\alpha) {
      any \beta {
        assume in(\beta,\alpha) {
          any \gamma {
            assume in(\gamma,\beta) {
              any \delta {
                assume in(\delta,\gamma) {
                  expand ordinal(\alpha) for ordinal
                  split trans(\alpha)\wedge irrefrelon(\alpha,mem(\alpha))\wedge worderon(\alpha,mem(\alpha))
                  expand trans(\alpha) for trans
                  apply invoke \forall y(in(y,\alpha)\to\forall z(in(z,y)\to in(z,\alpha))) for y:\beta
                  apply invoke \forall z(in(z,\beta)\to in(z,\alpha)) for z:\gamma
                  apply invoke \forall y(in(y,\alpha)\to\forall z(in(z,y)\to in(z,\alpha))) for y:\gamma
                  apply invoke \forall z(in(z,\gamma)\to in(z,\alpha)) for z:\delta
                  connect in(\gamma,\alpha)\wedge in(\beta,\alpha)\wedge in(\gamma,\beta)
                  apply invoke leftward mem_cor1 for X:\alpha,x:\gamma,y:\beta
                  connect in(\delta,\alpha)\wedge in(\gamma,\alpha)\wedge in(\delta,\gamma)
                  apply invoke leftward mem_cor1 for X:\alpha,x:\delta,y:\gamma
                  connect in(op(\delta,\gamma),mem(\alpha))\wedge in(op(\gamma,\beta),mem(\alpha))
                  expand worderon(\alpha,mem(\alpha)) for worderon
                  split 1 orderon(\alpha,mem(\alpha))\wedge\forall A(subset(A,\alpha)\wedge neq(A,emptyset)\to\exists a(minimum(\alpha,mem(\alpha),A,a)))
                  expand orderon(\alpha,mem(\alpha)) for orderon
                  split 2 relon(\alpha,mem(\alpha))\wedge order(mem(\alpha))
                  expand order(mem(\alpha)) for order
                  split 1 transrel(mem(\alpha))\wedge antisymrel(mem(\alpha))
                  expand transrel(mem(\alpha)) for transrel
                  apply invoke \forall x\forall y\forall z(in(op(x,y),mem(\alpha))\wedge in(op(y,z),mem(\alpha))\to in(op(x,z),mem(\alpha))) for x:\delta,y:\gamma,z:\beta
                  apply invoke rightward mem_cor1 for X:\alpha,x:\delta,y:\beta
                  split 3 in(\delta,\alpha)\wedge in(\beta,\alpha)\wedge in(\delta,\beta)
                }
              }
            }
          }
          fold for trans conclude trans(\beta)
        }
      }
    }
  }
}

theorem element_of_ordinal_is_ordinal \forall\alpha(ordinal(\alpha)\to\forall\beta(in(\beta,\alpha)\to ordinal(\beta))) {
  any \alpha {
    assume ordinal(\alpha) {
      any \beta {
        assume in(\beta,\alpha) {
          apply invoke element_of_ordinal_is_trans for \alpha:\alpha
          apply invoke \forall\beta(in(\beta,\alpha)\to trans(\beta)) for \beta:\beta
          expand ordinal(\alpha) for ordinal
          split trans(\alpha)\wedge irrefrelon(\alpha,mem(\alpha))\wedge worderon(\alpha,mem(\alpha))
          apply invoke rightward trans_cor1 for x:\alpha
          apply invoke \forall y(in(y,\alpha)\to subset(y,\alpha)) for y:\beta
          connect irrefrelon(\alpha,mem(\alpha))\wedge subset(\beta,\alpha)
          apply invoke mem_irrefrelon_subset for X:\alpha,Y:\beta
          connect worderon(\alpha,mem(\alpha))\wedge subset(\beta,\alpha)
          apply invoke mem_worderon_subset for X:\alpha,Y:\beta
          connect trans(\beta)\wedge irrefrelon(\beta,mem(\beta))\wedge worderon(\beta,mem(\beta))
          fold for ordinal conclude ordinal(\beta)
        }
      }
    }
  }
}
