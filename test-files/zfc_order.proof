include "zfc_separation.proof"

definition predicate transrelon(X, template \psi[2]) as \forall x\forall y\forall z(in(x,X)\wedge in(y,X)\wedge in(z,X)\to(\psi(x,y)\wedge\psi(y,z)\to\psi(x,z)))

definition predicate antisymrelon(X, template \psi[2]) as \forall x\forall y(in(x,X)\wedge in(y,X)\to(\psi(x,y)\wedge\psi(y,x)\to equal(x,y)))

definition predicate orderon(X, template \psi[2]) as transrelon(X,\psi)\wedge antisymrelon(X,\psi)

definition predicate irrefrelon(X, template \psi[2]) as \forall x(in(x,X)\to\neg(\psi(x,x)))

definition predicate linorder(X, template \psi[2]) as orderon(X,\psi)\wedge\forall x\forall y(in(x,X)\wedge in(y,X)\to\psi(x,y)\vee equal(x,y)\vee\psi(y,x))

definition function seg(X, template \psi[2], x) as sep(X,lambda y.neq(y,x)\wedge\psi(y,x))

theorem seg_characterization \forall X\forall^T\psi[2]\forall x\forall y(in(y,seg(X,\psi,x))\leftrightarrow in(y,X)\wedge neq(y,x)\wedge\psi(y,x)) {
  any X, template \psi[2],x,y {
    assume in(y,seg(X,\psi,x)) {
      expand in(y,seg(X,\psi,x)) for seg
      apply invoke rightward sep_existence for x:X,\phi:lambda y.neq(y,x)\wedge\psi(y,x),z:y
    }
    assume in(y,X)\wedge neq(y,x)\wedge\psi(y,x) {
      apply invoke leftward sep_existence for x:X,\phi:lambda y.neq(y,x)\wedge\psi(y,x),z:y
      fold for seg conclude in(y,seg(X,\psi,x))
    }
    connect in(y,seg(X,\psi,x))\leftrightarrow in(y,X)\wedge neq(y,x)\wedge\psi(y,x)
  }
}

definition predicate minimal(X, template \psi[2], A, a) as subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to\neg(\psi(x,a)))

theorem minimal_equivalence \forall X\forall^T\psi[2]\forall A\forall a(minimal(X,\psi,A,a)\leftrightarrow subset(A,X)\wedge in(a,A)\wedge equal(cap(seg(X,\psi,a),A),emptyset)) {
  any X, template \psi[2], A, a {
    assume minimal(X,\psi,A,a) {
      expand minimal(X,\psi,A,a) for minimal
      split subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to\neg(\psi(x,a)))
      any y {
        deny in(y,cap(seg(X,\psi,a),A)) {
          apply invoke rightward cap_characterization for x:seg(X,\psi,a),y:A,z:y
          split in(y,seg(X,\psi,a))\wedge in(y,A)
          apply invoke rightward seg_characterization for X:X,\psi:\psi,x:a,y:y
          split in(y,X)\wedge neq(y,a)\wedge\psi(y,a)
          connect in(y,A)\wedge neq(y,a)
          apply invoke \forall x(in(x,A)\wedge neq(x,a)\to\neg(\psi(x,a))) for x:y
          contradict \psi(y,a)
        }
      }
      apply invoke emptyset_uniqueness for x:cap(seg(X,\psi,a),A)
      connect subset(A,X)\wedge in(a,A)\wedge equal(cap(seg(X,\psi,a),A),emptyset)
    }
    assume subset(A,X)\wedge in(a,A)\wedge equal(cap(seg(X,\psi,a),A),emptyset) {
      split subset(A,X)\wedge in(a,A)\wedge equal(cap(seg(X,\psi,a),A),emptyset)
      any x {
        assume in(x,A)\wedge neq(x,a) {
          deny \psi(x,a) {
            split in(x,A)\wedge neq(x,a)
            connect in(x,A)\wedge subset(A,X)
            apply invoke subset_cor1 for z:x,x:A,y:X
            connect in(x,X)\wedge neq(x,a)\wedge\psi(x,a)
            apply invoke leftward seg_characterization for X:X,\psi:\psi,x:a,y:x
            connect in(x,seg(X,\psi,a))\wedge in(x,A)
            apply invoke leftward cap_characterization for x:seg(X,\psi,a),y:A,z:x
            substitute in(x,cap(seg(X,\psi,a),A)) for cap(seg(X,\psi,a),A):emptyset
            apply emptyset_existence for y:x
            contradict in(x,emptyset)
          }
        }
      }
      connect subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to\neg(\psi(x,a)))
      fold for minimal conclude minimal(X,\psi,A,a)
    }
    connect minimal(X,\psi,A,a)\leftrightarrow subset(A,X)\wedge in(a,A)\wedge equal(cap(seg(X,\psi,a),A),emptyset)
  }
}

definition predicate minimum(X, template \psi[2], A, a) as subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to\psi(a,x))

theorem minimum_implies_minimal \forall X\forall^T\psi[2]\forall A\forall a(antisymrelon(X,\psi)\wedge minimum(X,\psi,A,a)\to minimal(X,\psi,A,a)) {
  any X, template \psi[2], A, a {
    assume antisymrelon(X,\psi)\wedge minimum(X,\psi,A,a) {
      split antisymrelon(X,\psi)\wedge minimum(X,\psi,A,a)
      expand minimum(X,\psi,A,a) for minimum
      split subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to\psi(a,x))
      any x {
        assume in(x,A)\wedge neq(x,a) {
          split in(x,A)\wedge neq(x,a)
          deny \psi(x,a) {
            apply invoke \forall x(in(x,A)\wedge neq(x,a)\to\psi(a,x)) for x:x
            connect \psi(a,x)\wedge\psi(x,a)
            expand antisymrelon(X,\psi) for antisymrelon
            connect in(a,A)\wedge subset(A,X)
            apply invoke subset_cor1 for z:a,x:A,y:X
            connect in(x,A)\wedge subset(A,X)
            apply invoke subset_cor1 for z:x,x:A,y:X
            connect in(a,X)\wedge in(x,X)
            apply invoke \forall x\forall y(in(x,X)\wedge in(y,X)\to(\psi(x,y)\wedge\psi(y,x)\to equal(x,y))) for x:a,y:x
            invoke \psi(a,x)\wedge\psi(x,a)\to equal(a,x)
            contradict equal(a,x)
          }
        }
      }
      connect subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to\neg(\psi(x,a)))
      fold for minimal conclude minimal(X,\psi,A,a)
    }
  }
}

theorem linorder_and_minmal_implies_minimum \forall X\forall^T\psi[2]\forall A\forall a(linorder(X,\psi)\wedge minimal(X,\psi,A,a)\to minimum(X,\psi,A,a)) {
  any X, template \psi[2], A, a {
    assume linorder(X,\psi)\wedge minimal(X,\psi,A,a) {
      split linorder(X,\psi)\wedge minimal(X,\psi,A,a)
      expand minimal(X,\psi,A,a) for minimal
      split subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to\neg(\psi(x,a)))
      any x {
        assume in(x,A)\wedge neq(x,a) {
          apply invoke \forall x(in(x,A)\wedge neq(x,a)\to\neg(\psi(x,a))) for x:x
          split in(x,A)\wedge neq(x,a)
          expand linorder(X,\psi) for linorder
          split 2 orderon(X,\psi)\wedge\forall x\forall y(in(x,X)\wedge in(y,X)\to\psi(x,y)\vee equal(x,y)\vee\psi(y,x))
          connect in(x,A)\wedge subset(A,X)
          apply invoke subset_cor1 for z:x,x:A,y:X
          connect in(a,A)\wedge subset(A,X)
          apply invoke subset_cor1 for z:a,x:A,y:X
          connect in(x,X)\wedge in(a,X)
          apply invoke \forall x\forall y(in(x,X)\wedge in(y,X)\to\psi(x,y)\vee equal(x,y)\vee\psi(y,x)) for x:x,y:a
          divide \psi(x,a)\vee equal(x,a)\vee\psi(a,x)
            case \psi(x,a) {
              contradict \psi(x,a)
              explode \psi(a,x)
            }
            case equal(x,a) {
              contradict equal(x,a)
              explode \psi(a,x)
            }
            case \psi(a,x) {}
        }
      }
      connect subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to\psi(a,x))
      fold for minimum conclude minimum(X,\psi,A,a)
    }
  }
}

definition predicate wellfounded(X, template \psi[2]) as \forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimal(X,\psi,A,a)))

definition predicate wellorder(X, template \psi[2]) as orderon(X,\psi)\wedge\forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,\psi,A,a)))

theorem linorder_and_wellfounded_implies_wellorder \forall X\forall^T\psi[2](linorder(X,\psi)\wedge wellfounded(X,\psi)\to wellorder(X,\psi)) {
  any X, template \psi[2] {
    assume linorder(X,\psi)\wedge wellfounded(X,\psi) {
      split linorder(X,\psi)\wedge wellfounded(X,\psi)
      expand linorder(X,\psi) for linorder
      split orderon(X,\psi)\wedge\forall x\forall y(in(x,X)\wedge in(y,X)\to\psi(x,y)\vee equal(x,y)\vee\psi(y,x))
      any A {
        assume subset(A,X)\wedge neq(A,emptyset) {
          expand wellfounded(X,\psi) for wellfounded
          apply invoke \forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimal(X,\psi,A,a))) for A:A
          some a:a such \exists a(minimal(X,\psi,A,a)) {
            connect linorder(X,\psi)\wedge minimal(X,\psi,A,a)
            apply invoke linorder_and_minmal_implies_minimum for X:X,\psi:\psi,A:A,a:a
            lift for a:a conclude \exists a(minimum(X,\psi,A,a))
          }
        }
      }
      connect orderon(X,\psi)\wedge\forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,\psi,A,a)))
      fold for wellorder conclude wellorder(X,\psi)
    }
  }
}

theorem wellorder_implies_linorder \forall X\forall^T\psi[2](wellorder(X,\psi)\to linorder(X,\psi)) {
  any X, template \psi[2] {
    assume wellorder(X,\psi) {
      expand wellorder(X,\psi) for wellorder
      split orderon(X,\psi)\wedge\forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,\psi,A,a)))
      any x,y {
        assume in(x,X)\wedge in(y,X) {
          apply pair_cor9 for x:x,y:y
          apply invoke pair_cor10 for x:x,y:y,z:X
          connect subset(pair(x,y),X)\wedge neq(pair(x,y),emptyset)
          apply invoke \forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,\psi,A,a))) for A:pair(x,y)
          some a:a such \exists a(minimum(X,\psi,pair(x,y),a)) {
            expand minimum(X,\psi,pair(x,y),a) for minimum
            split subset(pair(x,y),X)\wedge in(a,pair(x,y))\wedge\forall z(in(z,pair(x,y))\wedge neq(z,a)\to\psi(a,z))
            apply invoke rightward pair_existence for x:x,y:y,w:a
            apply law_of_excluded_middle for \phi:lambda.equal(x,y)
            divide equal(x,y)\vee neq(x,y)
              case equal(x,y) {
                pad equal(x,y) conclude \psi(x,y)\vee equal(x,y)\vee\psi(y,x)
              }
              case neq(x,y) {
                divide equal(a,x)\vee equal(a,y)
                  case equal(a,x) {
                    substitute \forall z(in(z,pair(x,y))\wedge neq(z,a)\to\psi(a,z)) for a:x
                    apply pair_cor2 for x:x,y:y
                    connect in(y,pair(x,y))\wedge neq(y,x)
                    apply invoke \forall z(in(z,pair(x,y))\wedge neq(z,x)\to\psi(x,z)) for z:y
                    pad \psi(x,y) conclude \psi(x,y)\vee equal(x,y)\vee\psi(y,x)
                  }
                  case equal(a,y) {
                    substitute \forall z(in(z,pair(x,y))\wedge neq(z,a)\to\psi(a,z)) for a:y
                    apply pair_cor1 for x:x,y:y
                    connect in(x,pair(x,y))\wedge neq(x,y)
                    apply invoke \forall z(in(z,pair(x,y))\wedge neq(z,y)\to\psi(y,z)) for z:x
                    pad \psi(y,x) conclude \psi(x,y)\vee equal(x,y)\vee\psi(y,x)
                  }
              }
          }
        }
      }
      connect orderon(X,\psi)\wedge\forall x\forall y(in(x,X)\wedge in(y,X)\to\psi(x,y)\vee equal(x,y)\vee\psi(y,x))
      fold for linorder conclude linorder(X,\psi)
    }
  }
}

theorem wellorder_implies_wellfounded \forall X\forall^T\psi[2](wellorder(X,\psi)\to wellfounded(X,\psi)) {
  any X, template \psi[2] {
    assume wellorder(X,\psi) {
      expand wellorder(X,\psi) for wellorder
      split orderon(X,\psi)\wedge\forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,\psi,A,a)))
      expand orderon(X,\psi) for orderon
      split 2 transrelon(X,\psi)\wedge antisymrelon(X,\psi)
      any A {
        assume subset(A,X)\wedge neq(A,emptyset) {
          apply invoke \forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,\psi,A,a))) for A:A
          some a:a such \exists a(minimum(X,\psi,A,a)) {
            connect antisymrelon(X,\psi)\wedge minimum(X,\psi,A,a)
            apply invoke minimum_implies_minimal for X:X,\psi:\psi,A:A,a:a
            lift for a:a conclude \exists a(minimal(X,\psi,A,a))
          }
        }
      }
      fold for wellfounded conclude wellfounded(X,\psi)
    }
  }
}

theorem wellorder_equivalent_linorder_and_wellfounded \forall X\forall^T\psi[2](wellorder(X,\psi)\leftrightarrow linorder(X,\psi)\wedge wellfounded(X,\psi)) {
  any X, template \psi[2] {
    assume wellorder(X,\psi) {
      apply invoke wellorder_implies_linorder for X:X,\psi:\psi
      apply invoke wellorder_implies_wellfounded for X:X,\psi:\psi
      connect linorder(X,\psi)\wedge wellfounded(X,\psi)
    }
    assume linorder(X,\psi)\wedge wellfounded(X,\psi) {
      apply invoke linorder_and_wellfounded_implies_wellorder for X:X,\psi:\psi
    }
    connect wellorder(X,\psi)\leftrightarrow linorder(X,\psi)\wedge wellfounded(X,\psi)
  }
}

theorem transrelon_subset \forall X\forall^T\phi[2]\forall Y(transrelon(X,\phi)\wedge subset(Y,X)\to transrelon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume transrelon(X,\phi)\wedge subset(Y,X) {
      split transrelon(X,\phi)\wedge subset(Y,X)
      any x,y,z {
        assume in(x,Y)\wedge in(y,Y)\wedge in(z,Y) {
          split in(x,Y)\wedge in(y,Y)\wedge in(z,Y)
          connect in(x,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:x,x:Y,y:X
          connect in(y,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:y,x:Y,y:X
          connect in(z,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:z,x:Y,y:X
          connect in(x,X)\wedge in(y,X)\wedge in(z,X)
          expand transrelon(X,\phi) for transrelon
          apply invoke \forall x\forall y\forall z(in(x,X)\wedge in(y,X)\wedge in(z,X)\to(\phi(x,y)\wedge\phi(y,z)\to\phi(x,z))) for x:x,y:y,z:z
        }
      }
      fold for transrelon conclude transrelon(Y,\phi)
    }
  }
}

theorem antisymrelon_subset \forall X\forall^T\phi[2]\forall Y(antisymrelon(X,\phi)\wedge subset(Y,X)\to antisymrelon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume antisymrelon(X,\phi)\wedge subset(Y,X) {
      split antisymrelon(X,\phi)\wedge subset(Y,X)
      any x,y {
        assume in(x,Y)\wedge in(y,Y) {
          split in(x,Y)\wedge in(y,Y)
          connect in(x,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:x,x:Y,y:X
          connect in(y,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:y,x:Y,y:X
          connect in(x,X)\wedge in(y,X)
          expand antisymrelon(X,\phi) for antisymrelon
          apply invoke \forall x\forall y(in(x,X)\wedge in(y,X)\to(\phi(x,y)\wedge\phi(y,x)\to equal(x,y))) for x:x,y:y
        }
      }
      fold for antisymrelon conclude antisymrelon(Y,\phi)
    }
  }
}

theorem orderon_subset \forall X\forall^T\phi[2]\forall Y(orderon(X,\phi)\wedge subset(Y,X)\to orderon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume orderon(X,\phi)\wedge subset(Y,X) {
      split orderon(X,\phi)\wedge subset(Y,X)
      expand orderon(X,\phi) for orderon
      split transrelon(X,\phi)\wedge antisymrelon(X,\phi)
      connect transrelon(X,\phi)\wedge subset(Y,X)
      apply invoke transrelon_subset for X:X,\phi:\phi,Y:Y
      connect antisymrelon(X,\phi)\wedge subset(Y,X)
      apply invoke antisymrelon_subset for X:X,\phi:\phi,Y:Y
      connect transrelon(Y,\phi)\wedge antisymrelon(Y,\phi)
      fold for orderon conclude orderon(Y,\phi)
    }
  }
}

theorem irrefrelon_subset \forall X\forall^T\phi[2]\forall Y(irrefrelon(X,\phi)\wedge subset(Y,X)\to irrefrelon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume irrefrelon(X,\phi)\wedge subset(Y,X) {
      split irrefrelon(X,\phi)\wedge subset(Y,X)
      any x {
        assume in(x,Y) {
          connect in(x,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:x,x:Y,y:X
          expand irrefrelon(X,\phi) for irrefrelon
          apply invoke \forall x(in(x,X)\to\neg(\phi(x,x))) for x:x
        }
      }
      fold for irrefrelon conclude irrefrelon(Y,\phi)
    }
  }
}

theorem wellorder_subset \forall X\forall^T\phi[2]\forall Y(wellorder(X,\phi)\wedge subset(Y,X)\to wellorder(Y,\phi)) {
  any X, template \phi[2], Y {
    assume wellorder(X,\phi)\wedge subset(Y,X) {
      split wellorder(X,\phi)\wedge subset(Y,X)
      expand wellorder(X,\phi) for wellorder
      split orderon(X,\phi)\wedge\forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,\phi,A,a)))
      connect orderon(X,\phi)\wedge subset(Y,X)
      apply invoke orderon_subset for X:X,\phi:\phi,Y:Y
      any A {
        assume subset(A,Y)\wedge neq(A,emptyset) {
          split subset(A,Y)\wedge neq(A,emptyset)
          connect subset(A,Y)\wedge subset(Y,X)
          apply invoke subset_trans for x:A,y:Y,z:X
          connect subset(A,X)\wedge neq(A,emptyset)
          apply invoke \forall A(subset(A,X)\wedge neq(A,emptyset)\to\exists a(minimum(X,\phi,A,a))) for A:A
          some a:a such \exists a(minimum(X,\phi,A,a)) {
            expand minimum(X,\phi,A,a) for minimum
            split subset(A,X)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to\phi(a,x))
            connect subset(A,Y)\wedge in(a,A)\wedge\forall x(in(x,A)\wedge neq(x,a)\to\phi(a,x))
            fold for minimum conclude minimum(Y,\phi,A,a)
            lift for a:a conclude \exists a(minimum(Y,\phi,A,a))
          }
        }
      }
      connect orderon(Y,\phi)\wedge\forall A(subset(A,Y)\wedge neq(A,emptyset)\to\exists a(minimum(Y,\phi,A,a)))
      fold for wellorder conclude wellorder(Y,\phi)
    }
  }
}

theorem in_is_transrelon_emptyset transrelon(emptyset,in) {
  any x,y,z {
    assume in(x,emptyset)\wedge in(y,emptyset)\wedge in(z,emptyset) {
      split 1 in(x,emptyset)\wedge in(y,emptyset)\wedge in(z,emptyset)
      apply emptyset_existence for y:x
      contradict in(x,emptyset)
      explode in(x,y)\wedge in(y,z)\to in(x,z)
    }
  }
  fold for transrelon conclude transrelon(emptyset,in)
}

theorem in_is_antisymrelon_emptyset antisymrelon(emptyset,in) {
  any x,y {
    assume in(x,emptyset)\wedge in(y,emptyset) {
      split 1 in(x,emptyset)\wedge in(y,emptyset)
      apply emptyset_existence for y:x
      contradict in(x,emptyset)
      explode in(x,y)\wedge in(y,x)\to equal(x,y)
    }
  }
  fold for antisymrelon conclude antisymrelon(emptyset,in)
}

theorem in_is_orderon_emptyset orderon(emptyset,in) {
  assert in_is_transrelon_emptyset
  assert in_is_antisymrelon_emptyset
  connect transrelon(emptyset,in)\wedge antisymrelon(emptyset,in)
  fold for orderon conclude orderon(emptyset,in)
}

theorem in_is_irrefrelon_emptyset irrefrelon(emptyset,in) {
  any x {
    assume in(x,emptyset) {
      apply emptyset_existence for y:x
      contradict in(x,emptyset)
      explode notin(x,x)
    }
  }
  fold for irrefrelon conclude irrefrelon(emptyset,in)
}

theorem in_is_wellorder_emptyset wellorder(emptyset,in) {
  assert in_is_orderon_emptyset
  any A {
    assume subset(A,emptyset)\wedge neq(A,emptyset) {
      split subset(A,emptyset)\wedge neq(A,emptyset)
      apply invoke emptyset_subset_cor1 for x:A
      contradict equal(A,emptyset)
      explode \exists a(minimum(emptyset,in,A,a))
    }
  }
  connect orderon(emptyset,in)\wedge\forall A(subset(A,emptyset)\wedge neq(A,emptyset)\to\exists a(minimum(emptyset,in,A,a)))
  fold for wellorder conclude wellorder(emptyset,in)
}
