theorem test {
  conclude \forall x\forall y(x\in y\to x\in y) {
    any x, y conclude x\in y\to x\in y {
      assume x\in y conclude x\in y {}
    }
  }
}

theorem test {
  conclude \forall x\forall y(x\in y\to x\in y\wedge x\in y) {
    any x, y conclude x\in y\to x\in y\wedge x\in y {
      assume x\in y conclude x\in y\wedge x\in y {}
    }
  }
}

theorem test {
  conclude \forall x\forall y((x\in y\to x\in y)\wedge(x\in y\to x\in y)) {
    any x, y conclude (x\in y\to x\in y)\wedge(x\in y\to x\in y) {
      assume x\in y conclude x\in y {}
    }
  }
}

theorem test {
  conclude (\forall x\forall y(x\in y\to x\in y))\wedge(\forall z\forall w(z\in w\to z\in w)) {
    any x, y conclude x\in y\to x\in y {
      assume x\in y conclude x\in y {}
    }
  }
}

theorem test {
  conclude \forall x\forall y((x\in y\to x\in y)\wedge(x\in y\to x\in y\wedge x\in y)) {
    any x, y conclude (x\in y\to x\in y)\wedge(x\in y\to x\in y\wedge x\in y) {
      assume x\in y conclude x\in y {}
      assume x\in y conclude x\in y\wedge x\in y {}
    }
  }
}

theorem test {
  conclude (\forall x\forall y(x\in y\to x\in y))\wedge(\forall x\forall y(x\in y\to x\in y\wedge x\in y)) {
    any x, y conclude x\in y\to x\in y {
      assume x\in y conclude x\in y {}
    }
    any x, y conclude x\in y\to x\in y\wedge x\in y {
      assume x\in y conclude x\in y\wedge x\in y {}
    }
  }
}
