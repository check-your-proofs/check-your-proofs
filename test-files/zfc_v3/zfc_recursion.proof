include "zfc_function.proof"

definition predicate approx(g, n, a, function f[1]) as fun(g) \wedge dom(g, suc(n)) \wedge in(op(emptyset, a), g) \wedge \forall k (in(k, n) \to \exists p (in(op(k, p), g) \wedge in(op(suc(k), f(p)), g)))

definition predicate recursion(a, function f[1], n, x) as \exists g (approx(g, n, a, f) \wedge in(op(n, x), g))

theorem recursion_exists_base_step \forall c \forall^F f[1] (recursion(c, f, emptyset, c)) {
  any c, function f[1] {
    apply singleton_op_is_fun for emptyset, c
    apply singleton_op_dom for emptyset, c
    assert suc_emptyset_is_singleton_emptyset
    substitute dom(singleton(op(emptyset, c)), singleton(emptyset)) for singleton(emptyset): suc(emptyset)
    apply singleton_cor1 for op(emptyset, c)
    any k {
      assume in(k, emptyset) {
        apply emptyset_existence for k
        contradict in(k, emptyset)
        explode \exists p (in(op(k, p), singleton(op(emptyset, c))) \wedge in(op(suc(k), f(p)), singleton(op(emptyset, c))))
      }
    }
    connect approx(singleton(op(emptyset, c)), emptyset, c, f)
    connect approx(singleton(op(emptyset, c)), emptyset, c, f) \wedge in(op(emptyset, c), singleton(op(emptyset, c)))
    lift for singleton(op(emptyset, c)) conclude recursion(c, f, emptyset, c)
  }
}

theorem recursion_exists_induction_step \forall c \forall^F f[1] \forall n \forall x (natural(n) \wedge recursion(c, f, n, x) \to recursion(c, f, suc(n), f(x))) {
  any c, function f[1], n, x {
    assume natural(n) \wedge recursion(c, f, n, x) {
      split natural(n) \wedge recursion(c, f, n, x)
      apply invoke suc_of_natural_is_natural for n
      apply invoke natural_is_ordinal for suc(n)
      split ordinal(suc(n))
      some g such recursion(c, f, n, x) {
        split approx(g, n, c, f) \wedge in(op(n, x), g)
        split approx(g, n, c, f)
        deny \exists q (in(op(suc(n), q), g)) {
          some q such \exists q (in(op(suc(n), q), g)) {
            apply invoke leftward dom(g, suc(n)) for suc(n)
            apply invoke irrefrel_not_contain_itself for suc(n)
            contradict in(suc(n), suc(n))
          }
        }
        connect fun(g) \wedge \neg(\exists q (in(op(suc(n), q), g)))
        apply invoke adding_op_fun for g, suc(n), f(x)
        apply invoke adding_op_dom for g, suc(n), suc(n), f(x)
        fold for suc[2] conclude dom(adj(g, op(suc(n), f(x))), suc(suc(n)))
        apply invoke adj_cor1 for g, op(suc(n), f(x)), op(emptyset, c)
        apply adj_cor3 for g, op(suc(n), f(x))
        any k {
          assume in(k, suc(n)) {
            apply invoke rightward suc_characterization for n, k
            divide in(k, n) \vee equal(k, n)
              case in(k, n) {
                apply invoke \forall k (in(k, n) \to \exists p (in(op(k, p), g) \wedge in(op(suc(k), f(p)), g))) for k
                some p such \exists p (in(op(k, p), g) \wedge in(op(suc(k), f(p)), g)) {
                  split in(op(k, p), g) \wedge in(op(suc(k), f(p)), g)
                  apply invoke adj_cor1 for g, op(suc(n), f(x)), op(k, p)
                  apply invoke adj_cor1 for g, op(suc(n), f(x)), op(suc(k), f(p))
                  connect in(op(k, p), adj(g, op(suc(n), f(x)))) \wedge in(op(suc(k), f(p)), adj(g, op(suc(n), f(x))))
                  lift for p conclude \exists p (in(op(k, p), adj(g, op(suc(n), f(x)))) \wedge in(op(suc(k), f(p)), adj(g, op(suc(n), f(x)))))
                }
              }
              case equal(k, n) {
                apply invoke adj_cor1 for g, op(suc(n), f(x)), op(n, x)
                substitute in(op(n, x), adj(g, op(suc(n), f(x)))) for n[1]: k
                substitute in(op(suc(n), f(x)), adj(g, op(suc(n), f(x)))) for n[1]: k
                connect in(op(k, x), adj(g, op(suc(n), f(x)))) \wedge in(op(suc(k), f(x)), adj(g, op(suc(n), f(x))))
                lift for x conclude \exists p (in(op(k, p), adj(g, op(suc(n), f(x)))) \wedge in(op(suc(k), f(p)), adj(g, op(suc(n), f(x)))))
              }
          }
        }
        connect approx(adj(g, op(suc(n), f(x))), suc(n), c, f)
        connect approx(adj(g, op(suc(n), f(x))), suc(n), c, f) \wedge in(op(suc(n), f(x)), adj(g, op(suc(n), f(x))))
        lift for adj(g, op(suc(n), f(x))) conclude recursion(c, f, suc(n), f(x))
      }
    }
  }
}

theorem recursion_is_unique_base_step \forall c \forall^F f[1] \forall x (recursion(c, f, emptyset, x) \to equal(x, c)) {
  any c, function f[1], x {
    assume recursion(c, f, emptyset, x) {
      some g such recursion(c, f, emptyset, x) {
        split approx(g, emptyset, c, f) \wedge in(op(emptyset, x), g)
        split approx(g, emptyset, c, f)
        connect in(op(emptyset, x), g) \wedge in(op(emptyset, c), g)
        split 2 fun(g)
        apply invoke \forall x \forall y \forall y' (in(op(x, y), g) \wedge in(op(x, y'), g) \to equal(y, y')) for emptyset, x, c
      }
    }
  }
}

theorem recursion_is_unique_induction_step \forall c \forall^F f[1] \forall n \forall x (natural(n) \wedge \forall x' (recursion(c, f, n, x') \to equal(x', x)) \to \forall y (recursion(c, f, suc(n), y) \to equal(y, f(x)))) {
  any c, function f[1], n, x {
    assume natural(n) \wedge \forall x' (recursion(c, f, n, x') \to equal(x', x)) {
      any y {
        assume recursion(c, f, suc(n), y) {
          split natural(n) \wedge \forall x' (recursion(c, f, n, x') \to equal(x', x))
          apply invoke natural_is_ordinal for n
          split ordinal(n)
          apply invoke suc_of_natural_is_natural for n
          apply invoke natural_is_ordinal for suc(n)
          split ordinal(suc(n))
          some h' such recursion(c, f, suc(n), y) {
            split approx(h', suc(n), c, f) \wedge in(op(suc(n), y), h')
            split approx(h', suc(n), c, f)
            apply in_suc for n
            apply invoke \forall k (in(k, suc(n)) \to \exists p (in(op(k, p), h') \wedge in(op(suc(k), f(p)), h'))) for n
            some p such \exists p (in(op(n, p), h') \wedge in(op(suc(n), f(p)), h')) {
              split in(op(n, p), h') \wedge in(op(suc(n), f(p)), h')
              connect in(op(suc(n), f(p)), h') \wedge in(op(suc(n), y), h')
              split 2 fun(h')
              apply invoke \forall x \forall y \forall y' (in(op(x, y), h') \wedge in(op(x, y'), h') \to equal(y, y')) for suc(n), f(p), y
              apply invoke removing_op_fun for h', suc(n), y
              connect fun(h') \wedge dom(h', suc(suc(n))) \wedge in(op(suc(n), y), h')
              apply invoke removing_op_dom for h', suc(suc(n)), suc(n), y
              apply invoke irrefrel_not_contain_itself for suc(n)
              apply invoke rem_suc for suc(n)
              substitute dom(rem(h', op(suc(n), y)), rem(suc(suc(n)), suc(n))) for rem(suc(suc(n)), suc(n)): suc(n)
              apply suc_is_not_emptyset for n
              connect in(op(emptyset, c), h') \wedge neq(suc(n), emptyset)
              apply invoke removing_op_lem1 for h', emptyset, c, suc(n), y
              any k {
                assume in(k, n) {
                  pad in(k, n) conclude in(k, n) \vee equal(k, n)
                  apply invoke leftward suc_characterization for n, k
                  apply invoke \forall k (in(k, suc(n)) \to \exists p (in(op(k, p), h') \wedge in(op(suc(k), f(p)), h'))) for k
                  some p' such \exists p (in(op(k, p), h') \wedge in(op(suc(k), f(p)), h')) {
                    split in(op(k, p'), h') \wedge in(op(suc(k), f(p')), h')
                    deny equal(k, suc(n)) {
                      substitute in(k, suc(n)) for k: suc(n)
                      apply invoke irrefrel_not_contain_itself for suc(n)
                      contradict in(suc(n), suc(n))
                    }
                    connect in(op(k, p'), h') \wedge neq(k, suc(n))
                    apply invoke removing_op_lem1 for h', k, p', suc(n), y
                    deny equal(k, n) {
                      substitute in(k, n) for k: n
                      apply invoke irrefrel_not_contain_itself for n
                      contradict in(n, n)
                    }
                    connect natural(n) \wedge neq(k, n)
                    apply invoke natural_implies_suc_is_injection_contrapositive for n, k
                    connect in(op(suc(k), f(p')), h') \wedge neq(suc(k), suc(n))
                    apply invoke removing_op_lem1 for h', suc(k), f(p'), suc(n), y
                    connect in(op(k, p'), rem(h', op(suc(n), y))) \wedge in(op(suc(k), f(p')), rem(h', op(suc(n), y)))
                    lift for p' conclude \exists p' (in(op(k, p'), rem(h', op(suc(n), y))) \wedge in(op(suc(k), f(p')), rem(h', op(suc(n), y))))
                  }
                }
              }
              connect approx(rem(h', op(suc(n), y)), n, c, f)
              deny equal(n, suc(n)) {
                substitute in(n, suc(n)) for suc(n): n
                apply invoke irrefrel_not_contain_itself for n
                contradict in(n, n)
              }
              connect in(op(n, p), h') \wedge neq(n, suc(n))
              apply invoke removing_op_lem1 for h', n, p, suc(n), y
              connect approx(rem(h', op(suc(n), y)), n, c, f) \wedge in(op(n, p), rem(h', op(suc(n), y)))
              lift for rem(h', op(suc(n), y)) conclude recursion(c, f, n, p)
              apply invoke \forall x' (recursion(c, f, n, x') \to equal(x', x)) for p
              substitute equal(y, f(p)) for p: x
            }
          }          
        }
      }
    }
  }  
}

theorem recursion_exists_uniquely_base_step \forall c \forall^F f[1] \exists! x (recursion(c, f, emptyset, x)) {
  any c, function f[1] {
    apply recursion_exists_base_step for c, f
    any x {
      apply recursion_is_unique_base_step for c, f, x
    }
    connect recursion(c, f, emptyset, c) \wedge \forall x (recursion(c, f, emptyset, x) \to equal(x, c))
    characterize for c conclude \exists! x (recursion(c, f, emptyset, x))
  }
}

theorem recursion_exists_uniquely_induction_step \forall c \forall^F f[1] \forall n (natural(n) \wedge \exists! x (recursion(c, f, n, x)) \to \exists! x (recursion(c, f, suc(n), x))) {
  any c, function f[1], n {
    assume natural(n) \wedge \exists! x (recursion(c, f, n, x)) {
      split natural(n) \wedge \exists! x (recursion(c, f, n, x))
      apply invoke natural_is_ordinal for n
      split ordinal(n)
      some x such \exists! x (recursion(c, f, n, x)) {
        connect natural(n) \wedge recursion(c, f, n, x)
        apply invoke recursion_exists_induction_step for c, f, n, x
        connect natural(n) \wedge \forall x' (recursion(c, f, n, x') \to equal(x', x))
        apply invoke recursion_is_unique_induction_step for c, f, n, x
        connect recursion(c, f, suc(n), f(x)) \wedge \forall y' (recursion(c, f, suc(n), y') \to equal(y', f(x)))
        characterize for f(x) conclude \exists! x (recursion(c, f, suc(n), x))
      }
    }
  }
}

theorem recursion_exists_uniquely \forall c \forall^F f[1] \forall n (natural(n) \to \exists! x (recursion(c, f, n, x))) {
  any c, function f[1] {
    apply recursion_exists_uniquely_base_step for c, f
    any n {
      assume natural(n) {
        assume \exists! x (recursion(c, f, n, x)) {
          connect natural(n) \wedge \exists! x (recursion(c, f, n, x))
          apply invoke recursion_exists_uniquely_induction_step for c, f, n
        }
      }
    }
    connect \exists! x (recursion(c, f, emptyset, x)) \wedge \forall n (natural(n) \to (\exists! x (recursion(c, f, n, x)) \to \exists! x (recursion(c, f, suc(n), x))))
    apply invoke natural_induction for \lambda^P n. \exists! x (recursion(c, f, n, x))
  }
}

definition function iterate by recursion_exists_uniquely
existence iterate_existence \forall c \forall^F f[1] \forall n (natural(n) \to recursion(c, f, n, iterate(c, f, n))) by iterate
uniqueness iterate_uniqueness \forall c \forall^F f[1] \forall n (natural(n) \to \forall x (recursion(c, f, n, x) \to equal(x, iterate(c, f, n)))) by iterate

theorem iterate_characterization \forall c \forall^F f[1] (equal(iterate(c, f, emptyset), c) \wedge \forall n (natural(n) \to equal(iterate(c, f, suc(n)), f(iterate(c, f, n))))) {
  any c, function f[1] {
    assert emptyset_is_natural
    apply invoke iterate_existence for c, f, emptyset
    apply recursion_exists_base_step for c, f
    apply invoke iterate_uniqueness for c, f, emptyset
    apply invoke \forall x (recursion(c, f, emptyset, x) \to equal(x, iterate(c, f, emptyset))) for c
    any n {
      assume natural(n) {
        apply invoke suc_of_natural_is_natural for n
        apply invoke iterate_existence for c, f, n
        connect natural(n) \wedge recursion(c, f, n, iterate(c, f, n))
        apply invoke recursion_exists_induction_step for c, f, n, iterate(c, f, n)
        apply invoke iterate_uniqueness for c, f, suc(n)
        apply invoke \forall x (recursion(c, f, suc(n), x) \to equal(x, iterate(c, f, suc(n)))) for f(iterate(c, f, n))
      }
    }
    connect equal(iterate(c, f, emptyset), c) \wedge \forall n (natural(n) \to equal(iterate(c, f, suc(n)), f(iterate(c, f, n))))
  }
}

theorem natural_is_constructed_by_emptyset_and_suc \forall n (natural(n) \to equal(iterate(emptyset, suc, n), n)) {
  apply iterate_characterization for emptyset, suc
  split equal(iterate(emptyset, suc, emptyset), emptyset) \wedge \forall n (natural(n) \to equal(iterate(emptyset, suc, suc(n)), suc(iterate(emptyset, suc, n))))
  any n {
    assume natural(n) {
      apply invoke \forall n (natural(n) \to equal(iterate(emptyset, suc, suc(n)), suc(iterate(emptyset, suc, n)))) for n
      assume equal(iterate(emptyset, suc, n), n) {
        substitute equal(iterate(emptyset, suc, suc(n)), suc(iterate(emptyset, suc, n))) for iterate(emptyset, suc, n): n
      }
    }
  }
  connect equal(iterate(emptyset, suc, emptyset), emptyset) \wedge \forall n (natural(n) \to (equal(iterate(emptyset, suc, n), n) \to equal(iterate(emptyset, suc, suc(n)), suc(n))))
  apply invoke natural_induction for \lambda^P n. equal(iterate(emptyset, suc, n), n)
}
