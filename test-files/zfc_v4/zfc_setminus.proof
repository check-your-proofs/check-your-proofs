include "zfc_cap.proof"

definition function setminus(x, y) as sep(x, \lambda^P z. notin(z, y)) tex infix "\setminus"

theorem setminus_characterization \forall x \forall y \forall z (in(z, setminus(x, y)) \leftrightarrow in(z, x) \wedge notin(z, y)) {
  any x, y, z {
    assume in(z, setminus(x, y)) {
      expand in(z, setminus(x, y)) for setminus
      apply invoke rightward sep_existence for x, \lambda^P z. notin(z, y), z
    }
    assume in(z, x) \wedge notin(z, y) {
      apply invoke leftward sep_existence for x, \lambda^P z. notin(z, y), z
      fold for setminus conclude in(z, setminus(x, y))
    }
    connect in(z, setminus(x, y)) \leftrightarrow in(z, x) \wedge notin(z, y)
  }
}

theorem setminus_is_subset \forall x \forall y (subset(setminus(x, y), x)) {
  any x, y {
    any z {
      assume in(z, setminus(x, y)) {
        apply invoke rightward setminus_characterization for x, y, z
        split 1 in(z, x) \wedge notin(z, y)
      }
    }
    fold for subset conclude subset(setminus(x, y), x)
  }
}

theorem setminus_neq_emptyset_iff_exists_left_only \forall x \forall y (neq(setminus(x, y), emptyset) \leftrightarrow \exists z (in(z, x) \wedge notin(z, y))) {
  any x, y {
    assume neq(setminus(x, y), emptyset) {
      apply invoke not_emptyset_has_a_member for setminus(x, y)
      some z such \exists z (in(z, setminus(x, y))) {
        apply invoke rightward setminus_characterization for x, y, z
        lift for z conclude \exists z (in(z, x) \wedge notin(z, y))
      }
    }
    assume \exists z (in(z, x) \wedge notin(z, y)) {
      some z such \exists z (in(z, x) \wedge notin(z, y)) {
        apply invoke leftward setminus_characterization for x, y, z
        lift for z conclude \exists z (in(z, setminus(x, y)))
      }
      apply invoke has_a_member_not_emptyset for setminus(x, y)
    }
    connect neq(setminus(x, y), emptyset) \leftrightarrow \exists z (in(z, x) \wedge notin(z, y))
  }
}

theorem setminus_of_subsetneq_is_not_emptyset \forall x \forall y (subsetneq(y, x) \to neq(setminus(x, y), emptyset)) {
  any x, y {
    assume subsetneq(y, x) {
      split subsetneq(y, x)
      apply invoke rightward neg_equal for x, y
      some z such \exists z ((in(z, x) \wedge notin(z, y)) \vee (notin(z, x) \wedge in(z, y))) {
        divide (in(z, x) \wedge notin(z, y)) \vee (notin(z, x) \wedge in(z, y))
          case in(z, x) \wedge notin(z, y) {}
          case notin(z, x) \wedge in(z, y) {
            split notin(z, x) \wedge in(z, y)
            apply invoke subset(y, x) for z
            contradict in(z, x)
            explode in(z, x) \wedge notin(z, y)
          }
        lift for z conclude \exists z (in(z, x) \wedge notin(z, y))
      }
      apply invoke leftward setminus_neq_emptyset_iff_exists_left_only for x, y
    }
  }
}

theorem neg_subset_implies_subsetneq_is_not_emptyset \forall x \forall y (\neg(subset(x, y)) \to neq(setminus(x, y), emptyset)) {
  any x, y {
    assume \neg(subset(x, y)) {
      apply invoke rightward neg_subset for x, y
      apply invoke leftward setminus_neq_emptyset_iff_exists_left_only for x, y
    }
  }
}
