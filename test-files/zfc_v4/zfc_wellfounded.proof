include "zfc_setminus.proof"

definition predicate irrefrel(X, predicate \psi[2]) as \forall x (in(x, X) \to \neg(\psi(x, x)))

theorem subset_of_irrefrel_is_irrefrel \forall^P \phi[2] \forall x \forall y (irrefrel(x, \phi) \wedge subset(y, x) \to irrefrel(y, \phi)) {
  any predicate \phi[2], x, y {
    assume irrefrel(x, \phi) \wedge subset(y, x) {
      split irrefrel(x, \phi) \wedge subset(y, x)
      any z {
        assume in(z, y) {
          apply invoke subset(y, x) for z
          apply invoke irrefrel(x, \phi) for z
        }
      }
      fold for irrefrel conclude irrefrel(y, \phi)
    }
  }
}

theorem irrefrel_not_contain_itself \forall x (irrefrel(x, in) \to notin(x, x)) {
  any x {
    assume irrefrel(x, in) {
      deny in(x, x) {
        apply invoke irrefrel(x, in) for x
        contradict in(x, x)
      }
    }
  }
}

theorem adj_of_irrefrel_is_irrefrel \forall x \forall y \forall^P \psi[2] (irrefrel(x, \psi) \wedge \neg(\psi(y, y)) \to irrefrel(adj(x, y), \psi)) {
  any x, y, predicate \psi[2] {
    assume irrefrel(x, \psi) \wedge \neg(\psi(y, y)) {
      split irrefrel(x, \psi) \wedge \neg(\psi(y, y))
      any z {
        assume in(z, adj(x, y)) {
          apply invoke rightward adj_existence for x, y, z
          divide in(z, x) \vee equal(z, y)
            case in(z, x) {
              apply invoke irrefrel(x, \psi) for z
            }
            case equal(z, y) {
              substitute \neg(\psi(y, y)) for y: z
            }
        }
      }
      fold for irrefrel conclude irrefrel(adj(x, y), \psi)
    }
  }
}

definition predicate minimal_core(predicate \psi[2], A, a) as \forall x (in(x, A) \wedge neq(x, a) \to \neg(\psi(x, a)))

definition predicate minimal(predicate \psi[2], A, a) as in(a, A) \wedge minimal_core(\psi, A, a)

theorem element_is_minimal_in_its_singleton \forall x \forall^P \psi[2] (minimal(\psi, singleton(x), x)) {
  any x, predicate \psi[2] {
    apply singleton_cor1 for x
    any y {
      assume in(y, singleton(x)) \wedge neq(y, x) {
        split in(y, singleton(x)) \wedge neq(y, x)
        apply invoke rightward singleton_characterization for x, y
        contradict equal(y, x)
        explode \neg(\psi(y, x))
      }
    }
    fold for minimal_core conclude minimal_core(\psi, singleton(x), x)
    connect minimal(\psi, singleton(x), x)
  }
}

definition predicate wellfounded(X, predicate \psi[2]) as \forall A (subset(A, X) \wedge neq(A, emptyset) \to \exists a (minimal(\psi, A, a)))

theorem subset_of_wellfounded_is_wellfounded \forall^P \phi[2] \forall x \forall y (wellfounded(x, \phi) \wedge subset(y, x) \to wellfounded(y, \phi)) {
  any predicate \phi[2], x, y {
    assume wellfounded(x, \phi) \wedge subset(y, x) {
      split wellfounded(x, \phi) \wedge subset(y, x)
      any A {
        assume subset(A, y) \wedge neq(A, emptyset) {
          split subset(A, y) \wedge neq(A, emptyset)
          connect subset(A, y) \wedge subset(y, x)
          apply invoke subset_transivity for A, y, x
          connect subset(A, x) \wedge neq(A, emptyset)
          apply invoke wellfounded(x, \phi) for A
        }
      }
      fold for wellfounded conclude wellfounded(y, \phi)
    }
  }
}

definition predicate closed(X, predicate \psi[2]) as \forall x \forall y (in(x, X) \wedge \psi(y, x) \to in(y, X))

theorem adj_of_closed_is_closed \forall x \forall t \forall^P \psi[2] (closed(t, \psi) \wedge \forall y (\psi(y, x) \to in(y, t)) \to closed(adj(t, x), \psi)) {
  any x, t, predicate \psi[2] {
    assume closed(t, \psi) \wedge \forall y (\psi(y, x) \to in(y, t)) {
      split closed(t, \psi) \wedge \forall y (\psi(y, x) \to in(y, t))
      any y, z {
        assume in(y, adj(t, x)) \wedge \psi(z, y) {
          split in(y, adj(t, x)) \wedge \psi(z, y)
          apply invoke rightward adj_existence for t, x, y
          divide in(y, t) \vee equal(y, x)
            case in(y, t) {
              connect in(y, t) \wedge \psi(z, y)
              apply invoke closed(t, \psi) for y, z
            }
            case equal(y, x) {
              substitute \psi(z, y) for y: x
              apply invoke \forall y (\psi(y, x) \to in(y, t)) for z
            }
          apply invoke adj_cor1 for t, x, z
        }
      }
      fold for closed conclude closed(adj(t, x), \psi)
    }
  }
}

theorem adj_of_closed_wellfounded_is_wellfounded \forall x \forall y \forall^P \psi[2] (closed(x, \psi) \wedge wellfounded(x, \psi) \to wellfounded(adj(x, y), \psi)) {
  any x, y, predicate \psi[2] {
    assume closed(x, \psi) \wedge wellfounded(x, \psi) {
      split closed(x, \psi) \wedge wellfounded(x, \psi)
      apply law_of_excluded_middle for \lambda^P. in(y, x)
      divide in(y, x) \vee notin(y, x)
        case in(y, x) {
          apply invoke adj_equal for x, y
          substitute wellfounded(x, \psi) for x: adj(x, y)
        }
        case notin(y, x) {
          any A {
            assume subset(A, adj(x, y)) \wedge neq(A, emptyset) {
              split subset(A, adj(x, y)) \wedge neq(A, emptyset)
              apply law_of_excluded_middle for \lambda^P. equal(A, singleton(y))
              divide equal(A, singleton(y)) \vee neq(A, singleton(y))
                case equal(A, singleton(y)) {
                  apply element_is_minimal_in_its_singleton for y, \psi
                  substitute minimal(\psi, singleton(y), y) for singleton(y): A
                  lift for y conclude \exists y (minimal(\psi, A, y))
                }
                case neq(A, singleton(y)) {
                  apply invoke subset_adj_implies_subset_rem for A, x, y
                  connect neq(A, singleton(y)) \wedge neq(A, emptyset)
                  apply invoke neq_singleton_implies_rem_neq_emptyset for A, y
                  connect subset(rem(A, y), x) \wedge neq(rem(A, y), emptyset)
                  apply invoke wellfounded(x, \psi) for rem(A, y)
                  some a such \exists a (minimal(\psi, rem(A, y), a)) {
                    split minimal(\psi, rem(A, y), a)
                    apply invoke rightward rem_existence for A, y, a
                    split in(a, A) \wedge neq(a, y)
                    deny \neg(minimal_core(\psi, A, a)) {
                      expand \neg(minimal_core(\psi, A, a)) for minimal_core
                      apply invoke leftward exist_neg_leftrightarrow_neg_forall for \lambda^P x. in(x, A) \wedge neq(x, a) \to \neg(\psi(x, a))                      some b such \exists x (\neg(in(x, A) \wedge neq(x, a) \to \neg(\psi(x, a)))) {
                        apply invoke rightward neg_implication for \lambda^P. in(b, A) \wedge neq(b, a), \lambda^P. \neg(\psi(b, a))
                        split in(b, A) \wedge neq(b, a) \wedge \psi(b, a)
                        deny equal(b, y) {
                          substitute \psi(b, a) for b: y
                          apply invoke subset(rem(A, y), x) for a
                          connect \psi(y, a) \wedge in(a, x)
                          apply invoke closed(x, \psi) for a, y
                          contradict in(y, x)
                        }
                        connect in(b, A) \wedge neq(b, y)
                        apply invoke leftward rem_existence for A, y, b
                        connect in(b, rem(A, y)) \wedge neq(b, a)
                        apply invoke minimal_core(\psi, rem(A, y), a) for b
                        contradict \psi(b, a)
                      }
                    }
                    connect minimal(\psi, A, a)
                    lift for a conclude \exists a (minimal(\psi, A, a))
                  }
              }
            }
          }
          fold for wellfounded conclude wellfounded(adj(x, y), \psi)
        }
    }
  }
}

theorem wellfounded_induction \forall^P \psi[2] \forall^P \chi[1] \forall X (closed(X, \psi) \wedge irrefrel(X, \psi) \wedge wellfounded(X, \psi) \wedge \forall x (in(x, X) \to (\forall y (\psi(y, x) \to \chi(y)) \to \chi(x))) \to \forall x (in(x, X) \to \chi(x))) {
  any predicate \psi[2], predicate \chi[1], X {
    assume closed(X, \psi) \wedge irrefrel(X, \psi) \wedge wellfounded(X, \psi) \wedge \forall x (in(x, X) \to (\forall y (\psi(y, x) \to \chi(y)) \to \chi(x))) {
      split closed(X, \psi) \wedge irrefrel(X, \psi) \wedge wellfounded(X, \psi) \wedge \forall x (in(x, X) \to (\forall y (\psi(y, x) \to \chi(y)) \to \chi(x)))
      deny \neg(\forall x (in(x, X) \to \chi(x))) {
        apply invoke leftward exist_neg_leftrightarrow_neg_forall for \lambda^P x. in(x, X) \to \chi(x)
        some x such \exists x (\neg(in(x, X) \to \chi(x))) {
          apply invoke rightward neg_implication for \lambda^P. in(x, X), \lambda^P. \chi(x)
          split in(x, X) \wedge \neg(\chi(x))
          apply sep_is_subset for X, \lambda^P y. \neg(\chi(y))
          apply in_suc for x
          connect in(x, suc(x)) \wedge \neg(\chi(x))
          apply invoke leftward sep_existence for X, \lambda^P y. \neg(\chi(y)), x
          lift for x conclude \exists z (in(z, sep(X, \lambda^P y. \neg(\chi(y)))))
          apply invoke has_a_member_not_emptyset for sep(X, \lambda^P y. \neg(\chi(y)))
          connect subset(sep(X, \lambda^P y. \neg(\chi(y))), X) \wedge neq(sep(X, \lambda^P y. \neg(\chi(y))), emptyset)
          apply invoke wellfounded(X, \psi) for sep(X, \lambda^P y. \neg(\chi(y)))
          some z such \exists z (minimal(\psi, sep(X, \lambda^P y. \neg(\chi(y))), z)) {
            split minimal(\psi, sep(X, \lambda^P y. \neg(\chi(y))), z)
            apply invoke rightward sep_existence for X, \lambda^P y. \neg(\chi(y)), z
            split in(z, X) \wedge \neg(\chi(z))
            any y {
              assume \psi(y, z) {
                connect in(z, X) \wedge \psi(y, z)
                apply invoke closed(X, \psi) for z, y
                deny equal(y, z) {
                  substitute \psi(y, z) for y: z
                  apply invoke irrefrel(X, \psi) for z
                  contradict \psi(z, z)
                }
                deny \neg(\chi(y)) {
                  connect in(y, X) \wedge \neg(\chi(y))
                  apply invoke leftward sep_existence for X, \lambda^P m. \neg(\chi(m)), y
                  connect in(y, sep(X, \lambda^P m. \neg(\chi(m)))) \wedge neq(y, z)
                  apply invoke minimal_core(\psi, sep(X, \lambda^P m. \neg(\chi(m))), z) for y
                  contradict \psi(y, z)
                }
              }
            }
            apply invoke \forall x (in(x, X) \to (\forall y (\psi(y, x) \to \chi(y)) \to \chi(x))) for z
            invoke \forall y (\psi(y, z) \to \chi(y)) \to \chi(z)
            contradict \neg(\chi(z))
          }
        }
      }
    }
  }
}

definition predicate psubset(predicate \chi[1], predicate \phi[1]) as \forall x (\chi(x) \to \phi(x))

definition predicate pirrefrel(predicate \phi[1], predicate \psi[2]) as \forall x (\phi(x) \to \neg(\psi(x, x)))

theorem psubset_of_pirrefrel_is_pirrefrel \forall^P \phi[1] \forall^P \psi[2] \forall^P \chi[1] (pirrefrel(\phi, \psi) \wedge psubset(\chi, \phi) \to pirrefrel(\chi, \psi)) {
  any predicate \phi[1], predicate \psi[2], predicate \chi[1] {
    assume pirrefrel(\phi, \psi) \wedge psubset(\chi, \phi) {
      split pirrefrel(\phi, \psi) \wedge psubset(\chi, \phi)
      any x {
        assume \chi(x) {
          apply invoke psubset(\chi, \phi) for x
          apply invoke pirrefrel(\phi, \psi) for x
        }
      }
      fold for pirrefrel conclude pirrefrel(\chi, \psi)
    }
  }
}

definition predicate pwellfounded(predicate \phi[1], predicate \psi[2]) as \forall A ((\forall x (in(x, A) \to \phi(x))) \wedge neq(A, emptyset) \to \exists a (minimal(\psi, A, a)))

theorem psubset_of_pwellfounded_is_pwellfounded \forall^P \phi[1] \forall^P \psi[2] \forall^P \chi[1] (pwellfounded(\phi, \psi) \wedge psubset(\chi, \phi) \to pwellfounded(\chi, \psi)) {
  any predicate \phi[1], predicate \psi[2], predicate \chi[1] {
    assume pwellfounded(\phi, \psi) \wedge psubset(\chi, \phi) {
      split pwellfounded(\phi, \psi) \wedge psubset(\chi, \phi)
      any A {
        assume \forall x (in(x, A) \to \chi(x)) \wedge neq(A, emptyset) {
          split \forall x (in(x, A) \to \chi(x)) \wedge neq(A, emptyset)
          any x {
            assume in(x, A) {
              apply invoke \forall x (in(x, A) \to \chi(x)) for x
              apply invoke psubset(\chi, \phi) for x
            }
          }
          connect \forall x (in(x, A) \to \phi(x)) \wedge neq(A, emptyset)
          apply invoke pwellfounded(\phi, \psi) for A
        }
      }
      fold for pwellfounded conclude pwellfounded(\chi, \psi)
    }
  }
}

definition predicate pclosed(predicate \phi[1], predicate \psi[2]) as \forall x \forall y (\phi(x) \wedge \psi(y, x) \to \phi(y))

definition predicate rtcset(x, predicate \psi[2], r) as closed(r, \psi) \wedge in(x, r) \wedge \forall s (closed(s, \psi) \wedge in(x, s) \to subset(r, s))

theorem rtcset_is_unique \forall x \forall^P \psi[2] \forall r \forall r' (rtcset(x, \psi, r) \wedge rtcset(x, \psi, r') \to equal(r, r')) {
  any x, predicate \psi[2], r, r' {
    assume rtcset(x, \psi, r) \wedge rtcset(x, \psi, r') {
      split rtcset(x, \psi, r) \wedge rtcset(x, \psi, r')
      split rtcset(x, \psi, r)
      split rtcset(x, \psi, r')
      connect closed(r', \psi) \wedge in(x, r')
      apply invoke \forall s (closed(s, \psi) \wedge in(x, s) \to subset(r, s)) for r'
      connect closed(r, \psi) \wedge in(x, r)
      apply invoke \forall s (closed(s, \psi) \wedge in(x, s) \to subset(r', s)) for r
      connect subset(r, r') \wedge subset(r', r)
      apply invoke subset_antisymmetry for r, r'
    }
  }
}

definition predicate tcset(x, predicate \psi[2], t) as closed(t, \psi) \wedge \forall y (\psi(y, x) \to in(y, t)) \wedge \forall s (closed(s, \psi) \wedge \forall y (\psi(y, x) \to in(y, s)) \to subset(t, s))

theorem tcset_is_unique \forall x \forall^P \psi[2] \forall t \forall t' (tcset(x, \psi, t) \wedge tcset(x, \psi, t') \to equal(t, t')) {
  any x, predicate \psi[2], t, t' {
    assume tcset(x, \psi, t) \wedge tcset(x, \psi, t') {
      split tcset(x, \psi, t) \wedge tcset(x, \psi, t')
      split tcset(x, \psi, t)
      split tcset(x, \psi, t')
      connect closed(t', \psi) \wedge \forall y (\psi(y, x) \to in(y, t'))
      apply invoke \forall s (closed(s, \psi) \wedge \forall y (\psi(y, x) \to in(y, s)) \to subset(t, s)) for t'
      connect closed(t, \psi) \wedge \forall y (\psi(y, x) \to in(y, t))
      apply invoke \forall s (closed(s, \psi) \wedge \forall y (\psi(y, x) \to in(y, s)) \to subset(t', s)) for t
      connect subset(t, t') \wedge subset(t', t)
      apply invoke subset_antisymmetry for t, t'
    }
  }
}

theorem adj_of_tcset_is_rtcset \forall x \forall^P \psi[2] \forall t (tcset(x, \psi, t) \to rtcset(x, \psi, adj(t, x))) {
  any x, predicate \psi[2], t {
    assume tcset(x, \psi, t) {
      split tcset(x, \psi, t)
      connect closed(t, \psi) \wedge \forall y (\psi(y, x) \to in(y, t))
      apply invoke adj_of_closed_is_closed for x, t, \psi
      apply adj_cor3 for t, x
      any s {
        assume closed(s, \psi) \wedge in(x, s) {
          split closed(s, \psi) \wedge in(x, s)
          any y {
            assume in(y, adj(t, x)) {
              apply invoke rightward adj_existence for t, x, y
              divide in(y, t) \vee equal(y, x)
                case in(y, t) {
                  any z {
                    assume \psi(z, x) {
                      connect in(x, s) \wedge \psi(z, x)
                      apply invoke closed(s, \psi) for x, z
                    }
                  }
                  connect closed(s, \psi) \wedge \forall z (\psi(z, x) \to in(z, s))
                  apply invoke \forall s ((closed(s, \psi) \wedge \forall z (\psi(z, x) \to in(z, s))) \to subset(t, s)) for s
                  apply invoke subset(t, s) for y
                }
                case equal(y, x) {
                  substitute in(x, s) for x: y
                }
            }
          }
          fold for subset conclude subset(adj(t, x), s)
        }
      }
      connect closed(adj(t, x), \psi) \wedge in(x, adj(t, x)) \wedge \forall s (closed(s, \psi) \wedge in(x, s) \to subset(adj(t, x), s))
      fold for rtcset conclude rtcset(x, \psi, adj(t, x))
    }
  }
}

definition predicate rtcsetlike(predicate \phi[1], predicate \psi[2]) as \forall x (\phi(x) \to \exists r (rtcset(x, \psi, r)))

definition predicate tcsetlike(predicate \phi[1], predicate \psi[2]) as \forall x (\phi(x) \to \exists t (tcset(x, \psi, t)))

theorem tcsetlike_implies_rtcsetlike \forall^P \phi[1] \forall^P \psi[2] (tcsetlike(\phi, \psi) \to rtcsetlike(\phi, \psi)) {
  any predicate \phi[1], predicate \psi[2] {
    assume tcsetlike(\phi, \psi) {
      any x {
        assume \phi(x) {
          apply invoke tcsetlike(\phi, \psi) for x
          some t such \exists t (tcset(x, \psi, t)) {
            apply invoke adj_of_tcset_is_rtcset for x, \psi, t
            lift for adj(t, x) conclude \exists r (rtcset(x, \psi, r))
          }
        }
      }
      fold for rtcsetlike conclude rtcsetlike(\phi, \psi)
    }
  }
}

theorem psubset_of_rtcsetlike_is_rtcsetlike \forall^P \phi[1] \forall^P \psi[2] \forall^P \chi[1] (rtcsetlike(\phi, \psi) \wedge psubset(\chi, \phi) \to rtcsetlike(\chi, \psi)) {
  any predicate \phi[1], predicate \psi[2], predicate \chi[1] {
    assume rtcsetlike(\phi, \psi) \wedge psubset(\chi, \phi) {
      split rtcsetlike(\phi, \psi) \wedge psubset(\chi, \phi)
      any x {
        assume \chi(x) {
          apply invoke psubset(\chi, \phi) for x
          apply invoke rtcsetlike(\phi, \psi) for x
        }
      }
      fold for rtcsetlike conclude rtcsetlike(\chi, \psi)
    }
  }
}

theorem psubset_of_tcsetlike_is_tcsetlike \forall^P \phi[1] \forall^P \psi[2] \forall^P \chi[1] (tcsetlike(\phi, \psi) \wedge psubset(\chi, \phi) \to tcsetlike(\chi, \psi)) {
  any predicate \phi[1], predicate \psi[2], predicate \chi[1] {
    assume tcsetlike(\phi, \psi) \wedge psubset(\chi, \phi) {
      split tcsetlike(\phi, \psi) \wedge psubset(\chi, \phi)
      any x {
        assume \chi(x) {
          apply invoke psubset(\chi, \phi) for x
          apply invoke tcsetlike(\phi, \psi) for x
        }
      }
      fold for tcsetlike conclude tcsetlike(\chi, \psi)
    }
  }
}

theorem pwellfounded_induction \forall^P \phi[1] \forall^P \psi[2] \forall^P \chi[1] (tcsetlike(\phi, \psi) \wedge pclosed(\phi, \psi) \wedge pirrefrel(\phi, \psi) \wedge pwellfounded(\phi, \psi) \wedge \forall x (\phi(x) \wedge \forall y (\psi(y, x) \to \chi(y)) \to \chi(x)) \to \forall x (\phi(x) \to \chi(x))) {
  any predicate \phi[1], predicate \psi[2], predicate \chi[1] {
    assume tcsetlike(\phi, \psi) \wedge pclosed(\phi, \psi) \wedge pirrefrel(\phi, \psi) \wedge pwellfounded(\phi, \psi) \wedge \forall x (\phi(x) \wedge \forall y (\psi(y, x) \to \chi(y)) \to \chi(x)) {
      split tcsetlike(\phi, \psi) \wedge pclosed(\phi, \psi) \wedge pirrefrel(\phi, \psi) \wedge pwellfounded(\phi, \psi) \wedge \forall x (\phi(x) \wedge \forall y (\psi(y, x) \to \chi(y)) \to \chi(x))
      apply invoke tcsetlike_implies_rtcsetlike for \phi, \psi
      deny \neg(\forall x (\phi(x) \to \chi(x))) {
        apply invoke leftward exist_neg_leftrightarrow_neg_forall for \lambda^P x. \phi(x) \to \chi(x)
        some x such \exists x (\neg(\phi(x) \to \chi(x))) {
          apply invoke rightward neg_implication for \lambda^P. \phi(x), \lambda^P. \chi(x)
          split \phi(x) \wedge \neg(\chi(x))
          apply invoke rtcsetlike(\phi, \psi) for x
          some r such \exists r (rtcset(x, \psi, r)) {
            split rtcset(x, \psi, r)
            any y {
              assume in(y, sep(r, \lambda^P y. \phi(y) \wedge \neg(\chi(y)))) {
                apply invoke rightward sep_existence for r, \lambda^P y. \phi(y) \wedge \neg(\chi(y)), y
                split 2 in(y, r) \wedge \phi(y) \wedge \neg(\chi(y))
              }
            }
            connect in(x, r) \wedge \phi(x) \wedge \neg(\chi(x))
            apply invoke leftward sep_existence for r, \lambda^P y. \phi(y) \wedge \neg(\chi(y)), x
            lift for x conclude \exists z (in(z, sep(r, \lambda^P y. \phi(y) \wedge \neg(\chi(y)))))
            apply invoke has_a_member_not_emptyset for sep(r, \lambda^P y. \phi(y) \wedge \neg(\chi(y)))
            connect \forall y (in(y, sep(r, \lambda^P y'. \phi(y') \wedge \neg(\chi(y')))) \to \phi(y)) \wedge neq(sep(r, \lambda^P y. \phi(y) \wedge \neg(\chi(y))), emptyset)
            apply invoke pwellfounded(\phi, \psi) for sep(r, \lambda^P y. \phi(y) \wedge \neg(\chi(y)))
            some z such \exists z (minimal(\psi, sep(r, \lambda^P y. \phi(y) \wedge \neg(\chi(y))), z)) {
              split minimal(\psi, sep(r, \lambda^P y. \phi(y) \wedge \neg(\chi(y))), z)
              apply invoke rightward sep_existence for r, \lambda^P y. \phi(y) \wedge \neg(\chi(y)), z
              split in(z, r) \wedge \phi(z) \wedge \neg(\chi(z))
              any y {
                assume \psi(y, z) {
                  connect \phi(z) \wedge \psi(y, z)
                  apply invoke pclosed(\phi, \psi) for z, y
                  deny equal(y, z) {
                    substitute \psi(y, z) for y: z
                    apply invoke pirrefrel(\phi, \psi) for z
                    contradict \psi(z, z)
                  }
                  deny \neg(\chi(y)) {
                    connect in(z, r) \wedge \psi(y, z)
                    apply invoke closed(r, \psi) for z, y
                    connect in(y, r) \wedge \phi(y) \wedge \neg(\chi(y))
                    apply invoke leftward sep_existence for r, \lambda^P y. \phi(y) \wedge \neg(\chi(y)), y
                    connect in(y, sep(r, \lambda^P y. \phi(y) \wedge \neg(\chi(y)))) \wedge neq(y, z)
                    apply invoke minimal_core(\psi, sep(r, \lambda^P y. \phi(y) \wedge \neg(\chi(y))), z) for y
                    contradict \psi(y, z)
                  }
                }
              }
              connect \phi(z) \wedge \forall y (\psi(y, z) \to \chi(y))
              apply invoke \forall x (\phi(x) \wedge \forall y (\psi(y, x) \to \chi(y)) \to \chi(x)) for z
              contradict \neg(\chi(z))
            }
          }
        }
      }
    }
  }
}
