include "zfc_powerset.proof"

definition predicate tcm(X, Y) as tcset(X, in, Y)

theorem tcm_is_unique \forall X \forall Y \forall Y' (tcm(X, Y) \wedge tcm(X, Y') \to equal(Y, Y')) {
  any X, Y, Y' {
    assume tcm(X, Y) \wedge tcm(X, Y') {
      expand tcm(X, Y) \wedge tcm(X, Y') for tcm
      apply invoke tcset_is_unique for X, in, Y, Y'
    }
  }
}

theorem tcm_is_functional functional(tcm) {
  assert tcm_is_unique
  fold for functional conclude functional(tcm)
}

theorem tcm_implies_subset \forall X \forall Y (tcm(X, Y) \to subset(X, Y)) {
  any x, t {
    assume tcm(x, t) {
      expand tcm(x, t) for tcm
      split 2 tcset(x, in, t)
      fold for subset conclude subset(x, t)
    }
  }
}

theorem tcm_irrefrel_implies_not_contain_itself \forall X \forall Y (tcm(X, Y) \wedge irrefrel(Y, in) \to notin(X, X)) {
  any X, Y {
    assume tcm(X, Y) \wedge irrefrel(Y, in) {
      split tcm(X, Y) \wedge irrefrel(Y, in)
      apply invoke tcm_implies_subset for X, Y
      deny in(X, X) {
        apply invoke subset(X, Y) for X
        apply invoke irrefrel(Y, in) for X
        contradict in(X, X)
      }
    }
  }
}

theorem tcm_is_trans \forall X \forall Y (tcm(X, Y) \to trans(Y)) {
  any X, Y {
    assume tcm(X, Y) {
      expand tcm(X, Y) for tcm
      split 1 tcset(X, in, Y)
      apply invoke leftward trans_iff_closed_in for Y
    }
  }
}

theorem emptyset_is_closed \forall^P \psi[2] (closed(emptyset, \psi)) {
  any predicate \psi[2] {
    any x, y {
      assume in(x, emptyset) \wedge \psi(y, x) {
        split 1 in(x, emptyset) \wedge \psi(y, x)
        apply emptyset_existence for x
        contradict in(x, emptyset)
        explode in(y, emptyset)
      }
    }
    fold for closed conclude closed(emptyset, \psi)
  }
}

theorem emptyset_is_tcm_of_emptyset tcm(emptyset, emptyset) {
  apply emptyset_is_closed for in
  any y {
    assume in(y, emptyset) {}
  }
  any s {
    assume closed(s, in) \wedge \forall y (in(y, emptyset) \to in(y, s)) {
      apply emptyset_is_subset_of_any_set for s
    }
  }
  connect tcset(emptyset, in, emptyset)
  fold for tcm conclude tcm(emptyset, emptyset)
}

theorem tcm_is_tcm_of_itself \forall X \forall Y (tcm(X, Y) \to tcm(Y, Y)) {
  any X, Y {
    assume tcm(X, Y) {
      expand tcm(X, Y) for tcm
      split tcset(X, in, Y)
      apply invoke rightward closed_in_iff_tcset_of_itself for Y
      fold for tcm conclude tcm(Y, Y)
    }
  }
}

theorem tcm_adjunction \forall x \forall y \forall p \forall q \forall r (tcm(x, p) \wedge tcm(y, q) \wedge cup(p, q, r) \to tcm(adj(x, y), adj(r, y))) {
  any x, y, p, q, r {
    assume tcm(x, p) \wedge tcm(y, q) \wedge cup(p, q, r) {
      split tcm(x, p) \wedge tcm(y, q) \wedge cup(p, q, r)
      expand tcm(x, p) for tcm
      split tcset(x, in, p)
      expand tcm(y, q) for tcm
      split tcset(y, in, q)
      any z, w {
        assume in(z, adj(r, y)) \wedge in(w, z) {
          split in(z, adj(r, y)) \wedge in(w, z)
          apply invoke rightward adj_existence for r, y, z
          divide in(z, r) \vee equal(z, y)
            case in(z, r) {
              apply invoke rightward cup(p, q, r) for z
              divide in(z, p) \vee in(z, q)
                case in(z, p) {
                  connect in(z, p) \wedge in(w, z)
                  apply invoke closed(p, in) for z, w
                  pad in(w, p) conclude in(w, p) \vee in(w, q)
                  apply invoke leftward cup(p, q, r) for w
                }
                case in(z, q) {
                  connect in(z, q) \wedge in(w, z)
                  apply invoke closed(q, in) for z, w
                  pad in(w, q) conclude in(w, p) \vee in(w, q)
                  apply invoke leftward cup(p, q, r) for w
                }
            }
            case equal(z, y) {
              substitute in(w, z) for z: y
              apply invoke tcm_implies_subset for y, q
              apply invoke subset(y, q) for w
              pad in(w, q) conclude in(w, p) \vee in(w, q)
              apply invoke leftward cup(p, q, r) for w

            }
          apply invoke adj_cor1 for r, y, w
        }
      }
      fold for closed conclude closed(adj(r, y), in)
      any z {
        assume in(z, adj(x, y)) {
          apply invoke rightward adj_existence for x, y, z
          divide in(z, x) \vee equal(z, y)
            case in(z, x) {
              apply invoke tcm_implies_subset for x, p
              apply invoke subset(x, p) for z
              pad in(z, p) conclude in(z, p) \vee in(z, q)
              apply invoke leftward cup(p, q, r) for z
              apply invoke adj_cor1 for r, y, z
            }
            case equal(z, y) {
              apply invoke adj_cor2 for r, y, z
            }
        }
      }
      any s {
        assume closed(s, in) \wedge \forall z (in(z, adj(x, y)) \to in(z, s)) {
          split closed(s, in) \wedge \forall z (in(z, adj(x, y)) \to in(z, s))
          any z {
            assume in(z, adj(r, y)) {
              apply invoke rightward adj_existence for r, y, z
              apply adj_cor3 for x, y
              apply invoke \forall z (in(z, adj(x, y)) \to in(z, s)) for y
              divide in(z, r) \vee equal(z, y)
                case in(z, r) {
                  apply invoke rightward cup(p, q, r) for z
                  divide in(z, p) \vee in(z, q)
                    case in(z, p) {
                      any w {
                        assume in(w, x) {
                          apply invoke adj_cor1 for x, y, w
                          apply invoke \forall z (in(z, adj(x, y)) \to in(z, s)) for w
                        }
                      }
                      connect closed(s, in) \wedge \forall w (in(w, x) \to in(w, s))
                      apply invoke \forall s (closed(s, in) \wedge \forall w (in(w, x) \to in(w, s)) \to subset(p, s)) for s
                      apply invoke subset(p, s) for z
                    }
                    case in(z, q) {
                      any w {
                        assume in(w, y) {
                          connect in(w, y) \wedge in(y, s)
                          apply invoke closed(s, in) for y, w
                        }
                      }
                      connect closed(s, in) \wedge \forall w (in(w, y) \to in(w, s))
                      apply invoke \forall s (closed(s, in) \wedge \forall w (in(w, y) \to in(w, s)) \to subset(q, s)) for s
                      apply invoke subset(q, s) for z
                    }
                }
                case equal(z, y) {
                  substitute in(y, s) for y: z
                }
            }
          }
          fold for subset conclude subset(adj(r, y), s)
        }
      }
      connect tcset(adj(x, y), in, adj(r, y))
      fold for tcm conclude tcm(adj(x, y), adj(r, y))
    }
  }
}

theorem tcm_of_element_is_subset_of_tcm \forall x \forall t \forall y (tcm(x, t) \wedge in(y, x) \to \exists s (subset(s, t) \wedge tcm(y, s))) {
  any x, t, y {
    assume tcm(x, t) \wedge in(y, x) {
      split tcm(x, t) \wedge in(y, x)
      expand tcm(x, t) for tcm
      split tcset(x, in, t)
      apply invoke \forall y (in(y, x) \to in(y, t)) for y
      apply sep_is_subset for t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u))
      any z, w {
        assume in(z, sep(t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u)))) \wedge in(w, z) {
          split in(z, sep(t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u)))) \wedge in(w, z)
          apply invoke rightward sep_existence for t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u)), z
          split in(z, t) \wedge \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u))
          connect in(w, z) \wedge in(z, t)
          apply invoke closed(t, in) for z, w
          any u {
            assume closed(u, in) \wedge subset(y, u) {
              split closed(u, in) \wedge subset(y, u)
              apply invoke \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u)) for u
              connect in(w, z) \wedge in(z, u)
              apply invoke closed(u, in) for z, w
            }
          }
          connect in(w, t) \wedge \forall u (closed(u, in) \wedge subset(y, u) \to in(w, u))
          apply invoke leftward sep_existence for t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u)), w
        }
      }
      fold for closed[1] conclude closed(sep(t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u))), in)
      any z {
        assume in(z, y) {
          connect in(z, y) \wedge in(y, t)
          apply invoke closed(t, in) for y, z
          any u {
            assume closed(u, in) \wedge subset(y, u) {
              split closed(u, in) \wedge subset(y, u)
              apply invoke subset(y, u) for z
            }
          }
          connect in(z, t) \wedge \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u))
          apply invoke leftward sep_existence for t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u)), z
        }
      }
      any s {
        assume closed(s, in) \wedge \forall z (in(z, y) \to in(z, s)) {
          split closed(s, in) \wedge \forall z (in(z, y) \to in(z, s))
          fold for subset conclude subset(y, s)
          connect closed(s, in) \wedge subset(y, s)
          any z {
            assume in(z, sep(t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u)))) {
              apply invoke sep_satisfies_predicate for t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u)), z
              apply invoke \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u)) for s
            }
          }
          fold for subset[1] conclude subset(sep(t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u))), s)
        }
      }
      connect tcset(y, in, sep(t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u))))
      fold for tcm conclude tcm(y, sep(t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u))))
      connect subset(sep(t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u))), t) \wedge tcm(y, sep(t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u))))
      lift for sep(t, \lambda^P z. \forall u (closed(u, in) \wedge subset(y, u) \to in(z, u))) conclude \exists s (subset(s, t) \wedge tcm(y, s))
    }
  }
}

theorem tcm_is_cup_of_itself_and_bigcup_of_tcm_of_element \forall Y \forall Z \forall W \forall V (\forall y (in(y, Y) \to \exists z (tcm(y, z))) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V) \to tcm(Y, V)) {
  any Y, Z, W, V {
    assume \forall y (in(y, Y) \to \exists z (tcm(y, z))) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V) {
      split \forall y (in(y, Y) \to \exists z (tcm(y, z))) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V)
      any p, q {
        assume in(p, V) \wedge in(q, p) {
          split in(p, V) \wedge in(q, p)
          apply invoke rightward cup(Y, W, V) for p
          divide in(p, Y) \vee in(p, W)
            case in(p, Y) {
              apply invoke \forall y (in(y, Y) \to \exists z (tcm(y, z))) for p
              some z such \exists z (tcm(p, z)) {
                connect in(p, Y) \wedge tcm(p, z)
                lift for p conclude \exists y (in(y, Y) \wedge tcm(y, z))
                apply invoke leftward replacement(Y, tcm, Z) for z
                apply invoke tcm_implies_subset for p, z
                apply invoke subset(p, z) for q
                connect in(q, z) \wedge in(z, Z)
                lift for z conclude \exists z (in(q, z) \wedge in(z, Z))
                apply invoke leftward bigcup(Z, W) for q
              }
            }
            case in(p, W) {
              apply invoke rightward bigcup(Z, W) for p
              some z such \exists z (in(p, z) \wedge in(z, Z)) {
                split in(p, z) \wedge in(z, Z)
                apply invoke rightward replacement(Y, tcm, Z) for z
                some y such \exists y (in(y, Y) \wedge tcm(y, z)) {
                  split in(y, Y) \wedge tcm(y, z)
                  expand tcm(y, z) for tcm
                  split 1 tcset(y, in, z)
                  connect in(p, z) \wedge in(q, p)
                  apply invoke closed(z, in) for p, q
                  connect in(q, z) \wedge in(z, Z)
                  lift for z conclude \exists z (in(q, z) \wedge in(z, Z))
                }
              }
              apply invoke leftward bigcup(Z, W) for q
            }
          pad in(q, W) conclude in(q, Y) \vee in(q, W)
          apply invoke leftward cup(Y, W, V) for q
        }
      }
      fold for closed conclude closed(V, in)
      apply invoke subset_of_cup_left for Y, W, V
      expand subset(Y, V) for subset
      any s {
        assume closed(s, in) \wedge \forall y (in(y, Y) \to in(y, s)) {
          split closed(s, in) \wedge \forall y (in(y, Y) \to in(y, s))
          any v {
            assume in(v, V) {
              apply invoke rightward cup(Y, W, V) for v
              divide in(v, Y) \vee in(v, W)
                case in(v, Y) {
                  apply invoke \forall y (in(y, Y) \to in(y, s)) for v
                }
                case in(v, W) {
                  apply invoke rightward bigcup(Z, W) for v
                  some z such \exists z (in(v, z) \wedge in(z, Z)) {
                    split in(v, z) \wedge in(z, Z)
                    apply invoke rightward replacement(Y, tcm, Z) for z
                    some y such \exists y (in(y, Y) \wedge tcm(y, z)) {
                      split in(y, Y) \wedge tcm(y, z)
                      expand tcm(y, z) for tcm
                      split tcset(y, in, z)
                      show \forall u (in(u, y) \to in(u, s)) {
                        any u {
                          assume in(u, y) {
                            apply invoke \forall y (in(y, Y) \to in(y, s)) for y
                            connect in(u, y) \wedge in(y, s)
                            apply invoke closed(s, in) for y, u
                          }
                        }
                      }
                      connect closed(s, in) \wedge \forall u (in(u, y) \to in(u, s))
                      apply invoke \forall s (closed(s, in) \wedge \forall u (in(u, y) \to in(u, s)) \to subset(z, s)) for s
                      apply invoke subset(z, s) for v
                    }
                  }
                }
            }
          }
          fold for subset conclude subset(V, s)
        }
      }
      connect tcset(Y, in, V)
      fold for tcm conclude tcm(Y, V)
    }
  }
}
