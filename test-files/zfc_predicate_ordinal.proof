include "zfc_predicate_order.proof"

definition predicate cap(x,y,z) as \forall w(in(w,z)\leftrightarrow in(w,x)\wedge in(w,y))

theorem cap_is_subset_left \forall x\forall y\forall z(cap(x,y,z)\to subset(z,x)) {
  any x,y,z {
    assume cap(x,y,z) {
      any w {
        assume in(w,z) {
          expand cap(x,y,z) for cap
          apply invoke rightward \forall w(in(w,z)\leftrightarrow in(w,x)\wedge in(w,y)) for w:w
          split 1 in(w,x)\wedge in(w,y)
        }
      }
      fold for subset conclude subset(z,x)
    }
  }
}

theorem cap_is_subset_right \forall x\forall y\forall z(cap(x,y,z)\to subset(z,y)) {
  any x,y,z {
    assume cap(x,y,z) {
      any w {
        assume in(w,z) {
          expand cap(x,y,z) for cap
          apply invoke rightward \forall w(in(w,z)\leftrightarrow in(w,x)\wedge in(w,y)) for w:w
          split 2 in(w,x)\wedge in(w,y)
        }
      }
      fold for subset conclude subset(z,y)
    }
  }
}

definition predicate setminus(x,y,z) as \forall w(in(w,z)\leftrightarrow in(w,x)\wedge notin(w,y))

theorem setminus_is_subset \forall x\forall y\forall z(setminus(x,y,z)\to subset(z,x)) {
  any x,y,z {
    assume setminus(x,y,z) {
      any w {
        assume in(w,z) {
          expand setminus(x,y,z) for setminus
          apply invoke rightward \forall w(in(w,z)\leftrightarrow in(w,x)\wedge notin(w,y)) for w:w
          split 1 in(w,x)\wedge notin(w,y)
        }
      }
      fold for subset conclude subset(z,x)
    }
  }
}

definition predicate trans(x) as \forall y\forall z(in(z,y)\wedge in(y,x)\to in(z,x))

theorem trans_cor1 \forall x(trans(x)\leftrightarrow\forall y(in(y,x)\to subset(y,x))) {
  any x {
    assume trans(x) {
      expand trans(x) for trans
      any y {
        assume in(y,x) {
          any z {
            assume in(z,y) {
              connect in(z,y)\wedge in(y,x)
              apply invoke \forall y\forall z(in(z,y)\wedge in(y,x)\to in(z,x)) for y:y,z:z
            }
          }
          fold for subset conclude subset(y,x)
        }
      }
    }
    assume \forall y(in(y,x)\to subset(y,x)) {
      any y,z {
        assume in(z,y)\wedge in(y,x) {
          split in(z,y)\wedge in(y,x)
          apply invoke \forall y(in(y,x)\to subset(y,x)) for y:y
          connect in(z,y)\wedge subset(y,x)
          apply invoke subset_cor1 for z:z,x:y,y:x
        }
      }
      fold for trans conclude trans(x)
    }
    connect trans(x)\leftrightarrow\forall y(in(y,x)\to subset(y,x))
  }
}

theorem cap_of_trans_is_trans \forall x\forall y\forall z(trans(x)\wedge trans(y)\wedge cap(x,y,z)\to trans(z)) {
  any x,y,z {
    assume trans(x)\wedge trans(y)\wedge cap(x,y,z) {
      split trans(x)\wedge trans(y)\wedge cap(x,y,z)
      any w,v {
        assume in(v,w)\wedge in(w,z) {
          split in(v,w)\wedge in(w,z)
          expand cap(x,y,z) for cap
          apply invoke rightward \forall w(in(w,z)\leftrightarrow in(w,x)\wedge in(w,y)) for w:w
          split in(w,x)\wedge in(w,y)
          connect in(v,w)\wedge in(w,x)
          expand trans(x) for trans
          apply invoke \forall w\forall v(in(v,w)\wedge in(w,x)\to in(v,x)) for w:w,v:v
          expand trans(y) for trans
          connect in(v,w)\wedge in(w,y)
          apply invoke \forall w\forall v(in(v,w)\wedge in(w,y)\to in(v,y)) for w:w,v:v
          connect in(v,x)\wedge in(v,y)
          apply invoke leftward \forall w(in(w,z)\leftrightarrow in(w,x)\wedge in(w,y)) for w:v
        }
      }
      fold for trans conclude trans(z)
    }
  }
}

definition predicate ordinal(\alpha) as trans(\alpha)\wedge irrefrelon(\alpha,in)\wedge wellorder(\alpha,in)

theorem element_of_ordinal_is_trans \forall\alpha(ordinal(\alpha)\to\forall\beta(in(\beta,\alpha)\to trans(\beta))) {
  any \alpha {
    assume ordinal(\alpha) {
      any \beta {
        assume in(\beta,\alpha) {
          any \gamma,\delta {
            assume in(\delta,\gamma)\wedge in(\gamma,\beta) {
              split in(\delta,\gamma)\wedge in(\gamma,\beta)
              expand ordinal(\alpha) for ordinal
              split trans(\alpha)\wedge irrefrelon(\alpha,in)\wedge wellorder(\alpha,in)
              expand trans(\alpha) for trans
              connect in(\gamma,\beta)\wedge in(\beta,\alpha)
              apply invoke \forall y\forall z(in(z,y)\wedge in(y,\alpha)\to in(z,\alpha)) for y:\beta,z:\gamma
              connect in(\delta,\gamma)\wedge in(\gamma,\alpha)
              apply invoke \forall y\forall z(in(z,y)\wedge in(y,\alpha)\to in(z,\alpha)) for y:\gamma,z:\delta
              connect in(\gamma,\alpha)\wedge in(\beta,\alpha)\wedge in(\gamma,\beta)
              connect in(\delta,\alpha)\wedge in(\gamma,\alpha)\wedge in(\delta,\gamma)
              connect in(\delta,\gamma)\wedge in(\gamma,\beta)
              connect in(\delta,\alpha)\wedge in(\gamma,\alpha)\wedge in(\beta,\alpha)
              expand wellorder(\alpha,in) for wellorder
              split 1 orderon(\alpha,in)\wedge\forall^T\phi[1](\exists z(in(z,\alpha)\wedge\phi(z))\to\exists a(minimum(\alpha,in,\phi,a)))
              expand orderon(\alpha,in) for orderon
              split 1 transrelon(\alpha,in)\wedge antisymrelon(\alpha,in)
              expand transrelon(\alpha,in) for transrelon
              apply invoke \forall x\forall y\forall z(in(x,\alpha)\wedge in(y,\alpha)\wedge in(z,\alpha)\to(in(x,y)\wedge in(y,z)\to in(x,z))) for x:\delta,y:\gamma,z:\beta
              invoke in(\delta,\gamma)\wedge in(\gamma,\beta)\to in(\delta,\beta)
            }
          }
          fold for trans conclude trans(\beta)
        }
      }
    }
  }
}

theorem element_of_ordinal_is_ordinal \forall\alpha(ordinal(\alpha)\to\forall\beta(in(\beta,\alpha)\to ordinal(\beta))) {
  any \alpha {
    assume ordinal(\alpha) {
      any \beta {
        assume in(\beta,\alpha) {
          apply invoke element_of_ordinal_is_trans for \alpha:\alpha
          apply invoke \forall\beta(in(\beta,\alpha)\to trans(\beta)) for \beta:\beta
          expand ordinal(\alpha) for ordinal
          split trans(\alpha)\wedge irrefrelon(\alpha,in)\wedge wellorder(\alpha,in)
          apply invoke rightward trans_cor1 for x:\alpha
          apply invoke \forall y(in(y,\alpha)\to subset(y,\alpha)) for y:\beta
          connect irrefrelon(\alpha,in)\wedge subset(\beta,\alpha)
          apply invoke irrefrelon_subset for X:\alpha,\phi:in,Y:\beta
          connect wellorder(\alpha,in)\wedge subset(\beta,\alpha)
          apply invoke wellorder_subset for X:\alpha,\psi:in,Y:\beta
          connect trans(\beta)\wedge irrefrelon(\beta,in)\wedge wellorder(\beta,in)
          fold for ordinal conclude ordinal(\beta)
        }
      }
    }
  }
}

theorem ordinal_not_contain_itself \forall\alpha(ordinal(\alpha)\to notin(\alpha,\alpha)) {
  any \alpha {
    assume ordinal(\alpha) {
      expand ordinal(\alpha) for ordinal
      split 2 trans(\alpha)\wedge irrefrelon(\alpha,in)\wedge wellorder(\alpha,in)
      expand irrefrelon(\alpha,in) for irrefrelon
      apply \forall x(in(x,\alpha)\to notin(x,x)) for x:\alpha
      deny in(\alpha,\alpha) {
        invoke in(\alpha,\alpha)\to notin(\alpha,\alpha)
        contradict in(\alpha,\alpha)
      }
    }
  }
}

theorem ordianl_trans \forall\alpha\forall\beta\forall\gamma(ordinal(\alpha)\wedge in(\gamma,\beta)\wedge in(\beta,\alpha)\to in(\gamma,\alpha)) {
  any \alpha,\beta,\gamma {
    assume ordinal(\alpha)\wedge in(\gamma,\beta)\wedge in(\beta,\alpha) {
      split ordinal(\alpha)\wedge in(\gamma,\beta)\wedge in(\beta,\alpha)
      expand ordinal(\alpha) for ordinal
      split 1 trans(\alpha)\wedge irrefrelon(\alpha,in)\wedge wellorder(\alpha,in)
      expand trans(\alpha) for trans
      connect in(\gamma,\beta)\wedge in(\beta,\alpha)
      apply invoke \forall y\forall z(in(z,y)\wedge in(y,\alpha)\to in(z,\alpha)) for y:\beta,z:\gamma
    }
  }
}

theorem ordinal_subsetneq_of_ordinal_is_element \forall\alpha(ordinal(\alpha)\to\forall\beta(subsetneq(\beta,\alpha)\wedge ordinal(\beta)\to in(\beta,\alpha))) {
  any \alpha {
    assume ordinal(\alpha) {
      any \beta {
        assume subsetneq(\beta,\alpha)\wedge ordinal(\beta) {
          split subsetneq(\beta,\alpha)\wedge ordinal(\beta)
          apply invoke subsetneq_implies_exist for x:\beta,y:\alpha
          expand ordinal(\alpha) for ordinal
          split trans(\alpha)\wedge irrefrelon(\alpha,in)\wedge wellorder(\alpha,in)
          expand wellorder(\alpha,in) for wellorder
          split orderon(\alpha,in)\wedge\forall^T\phi[1](\exists z(in(z,\alpha)\wedge\phi(z))\to\exists a(minimum(\alpha,in,\phi,a)))
          apply invoke \forall^T\phi[1](\exists z(in(z,\alpha)\wedge\phi(z))\to\exists a(minimum(\alpha,in,\phi,a))) for \phi:lambda\gamma.notin(\gamma,\beta)
          some a:\gamma such \exists a(minimum(\alpha,in,lambda\gamma.notin(\gamma,\beta),a)) {
            expand minimum(\alpha,in,lambda\gamma.notin(\gamma,\beta),\gamma) for minimum
            split in(\gamma,\alpha)\wedge notin(\gamma,\beta)\wedge\forall x(in(x,\alpha)\wedge notin(x,\beta)\wedge neq(x,\gamma)\to in(\gamma,x))
            any \delta {
              assume in(\delta,\gamma) {
                deny notin(\delta,\beta) {
                  connect in(\delta,\gamma)\wedge in(\gamma,\alpha)
                  expand trans(\alpha) for trans
                  apply invoke \forall y\forall z(in(z,y)\wedge in(y,\alpha)\to in(z,\alpha)) for y:\gamma,z:\delta
                  connect in(\delta,\alpha)\wedge notin(\delta,\beta)
                  connect in(\delta,\gamma)\wedge in(\delta,\alpha)\wedge in(\gamma,\alpha)
                  show neq(\delta,\gamma) {
                    expand irrefrelon(\alpha,in) for irrefrelon
                    deny equal(\delta,\gamma) {
                      substitute in(\delta,\gamma) for \delta:\gamma
                      apply invoke \forall x(in(x,\alpha)\to notin(x,x)) for x:\gamma
                      contradict in(\gamma,\gamma)
                    }
                  }
                  connect in(\delta,\alpha)\wedge notin(\delta,\beta)\wedge neq(\delta,\gamma)
                  apply invoke \forall x(in(x,\alpha)\wedge notin(x,\beta)\wedge neq(x,\gamma)\to in(\gamma,x)) for x:\delta
                  connect in(\delta,\gamma)\wedge in(\gamma,\delta)
                  expand orderon(\alpha,in) for orderon
                  split 2 transrelon(\alpha,in)\wedge antisymrelon(\alpha,in)
                  expand antisymrelon(\alpha,in) for antisymrelon
                  connect in(\delta,\alpha)\wedge in(\gamma,\alpha)
                  apply invoke \forall x\forall y(in(x,\alpha)\wedge in(y,\alpha)\to(in(x,y)\wedge in(y,x)\to equal(x,y))) for x:\delta,y:\gamma
                  invoke in(\delta,\gamma)\wedge in(\gamma,\delta)\to equal(\delta,\gamma)
                  contradict equal(\delta,\gamma)
                }
              }
              assume in(\delta,\beta) {
                expand subsetneq(\beta,\alpha) for subsetneq
                split 1 subset(\beta,\alpha)\wedge neq(\beta,\alpha)
                connect in(\delta,\beta)\wedge subset(\beta,\alpha)
                apply invoke subset_cor1 for z:\delta,x:\beta,y:\alpha
                connect in(\delta,\alpha)\wedge in(\gamma,\alpha)
                apply invoke wellorder_implies_linorder for X:\alpha,\psi:in
                expand linorder(\alpha,in) for linorder
                split 2 orderon(\alpha,in)\wedge\forall x\forall y(in(x,\alpha)\wedge in(y,\alpha)\to in(x,y)\vee equal(x,y)\vee in(y,x))
                apply invoke \forall x\forall y(in(x,\alpha)\wedge in(y,\alpha)\to in(x,y)\vee equal(x,y)\vee in(y,x)) for x:\delta,y:\gamma
                divide in(\delta,\gamma)\vee equal(\delta,\gamma)\vee in(\gamma,\delta)
                  case in(\delta,\gamma) {}
                  case equal(\delta,\gamma) {
                    substitute in(\delta,\beta) for \delta:\gamma
                    contradict in(\gamma,\beta)
                    explode in(\delta,\gamma)
                  }
                  case in(\gamma,\delta) {
                    connect in(\gamma,\delta)\wedge in(\delta,\beta)
                    expand ordinal(\beta) for ordinal
                    split 1 trans(\beta)\wedge irrefrelon(\beta,in)\wedge wellorder(\beta,in)
                    expand trans(\beta) for trans
                    apply invoke \forall y\forall z(in(z,y)\wedge in(y,\beta)\to in(z,\beta)) for y:\delta,z:\gamma
                    contradict in(\gamma,\beta)
                    explode in(\delta,\gamma)
                  }
              }
              connect in(\delta,\gamma)\leftrightarrow in(\delta,\beta)
            }
            fold for equal conclude equal(\gamma,\beta)
            substitute in(\gamma,\alpha) for \gamma:\beta
          }
        }
      }
    }
  }
}

theorem ordinal_in_iff_subsetneq \forall\alpha\forall\beta(ordinal(\alpha)\wedge ordinal(\beta)\to(in(\alpha,\beta)\leftrightarrow subsetneq(\alpha,\beta))) {
  any \alpha,\beta {
    assume ordinal(\alpha)\wedge ordinal(\beta) {
      split ordinal(\alpha)\wedge ordinal(\beta)
      assume in(\alpha,\beta) {
        expand ordinal(\beta) for ordinal
        split 1 trans(\beta)\wedge irrefrelon(\beta,in)\wedge wellorder(\beta,in)
        apply invoke rightward trans_cor1 for x:\beta
        apply invoke \forall y(in(y,\beta)\to subset(y,\beta)) for y:\alpha
        deny equal(\alpha,\beta) {
          substitute in(\alpha,\beta) for \beta:\alpha
          apply invoke ordinal_not_contain_itself for \alpha:\alpha
          contradict in(\alpha,\alpha)
        }
        connect subset(\alpha,\beta)\wedge neq(\alpha,\beta)
        fold for subsetneq conclude subsetneq(\alpha,\beta)
      }
      assume subsetneq(\alpha,\beta) {
        apply invoke ordinal_subsetneq_of_ordinal_is_element for \alpha:\beta
        connect ordinal(\alpha)\wedge subsetneq(\alpha,\beta)
        apply invoke \forall\alpha(ordinal(\alpha)\wedge subsetneq(\alpha,\beta)\to in(\alpha,\beta)) for \alpha:\alpha
      }
      connect in(\alpha,\beta)\leftrightarrow subsetneq(\alpha,\beta)
    }
  }
}

theorem cap_of_ordinals_is_ordinal \forall\alpha\forall\beta\forall\gamma(ordinal(\alpha)\wedge ordinal(\beta)\wedge cap(\alpha,\beta,\gamma)\to ordinal(\gamma)) {
  any \alpha,\beta,\gamma {
    assume ordinal(\alpha)\wedge ordinal(\beta)\wedge cap(\alpha,\beta,\gamma) {
      split ordinal(\alpha)\wedge ordinal(\beta)\wedge cap(\alpha,\beta,\gamma)
      expand ordinal(\alpha) for ordinal
      split trans(\alpha)\wedge irrefrelon(\alpha,in)\wedge wellorder(\alpha,in)
      expand ordinal(\beta) for ordinal
      split trans(\beta)\wedge irrefrelon(\beta,in)\wedge wellorder(\beta,in)
      connect trans(\alpha)\wedge trans(\beta)\wedge cap(\alpha,\beta,\gamma)
      apply invoke cap_of_trans_is_trans for x:\alpha,y:\beta,z:\gamma
      apply invoke cap_is_subset_left for x:\alpha,y:\beta,z:\gamma
      connect irrefrelon(\alpha,in)\wedge subset(\gamma,\alpha)
      apply invoke irrefrelon_subset for X:\alpha,\phi:in,Y:\gamma
      connect wellorder(\alpha,in)\wedge subset(\gamma,\alpha)
      apply invoke wellorder_subset for X:\alpha,\psi:in,Y:\gamma
      connect trans(\gamma)\wedge irrefrelon(\gamma,in)\wedge wellorder(\gamma,in)
      fold for ordinal conclude ordinal(\gamma)
    }
  }
}

theorem ordinals_comparable_subset \forall\alpha\forall\beta(ordinal(\alpha)\wedge ordinal(\beta)\to subset(\alpha,\beta)\vee subset(\beta,\alpha)) {
  any \alpha,\beta {
    assume ordinal(\alpha)\wedge ordinal(\beta) {
      split ordinal(\alpha)\wedge ordinal(\beta)
      expand ordinal(\alpha) for ordinal
      split trans(\alpha)\wedge irrefrelon(\alpha,in)\wedge wellorder(\alpha,in)
      expand trans(\alpha) for trans
      expand irrefrelon(\alpha,in) for irrefrelon
      expand wellorder(\alpha,in) for wellorder
      split orderon(\alpha,in)\wedge\forall^T\phi[1](\exists z(in(z,\alpha)\wedge\phi(z))\to\exists a(minimum(\alpha,in,\phi,a)))
      expand orderon(\alpha,in) for orderon
      split transrelon(\alpha,in)\wedge antisymrelon(\alpha,in)
      expand ordinal(\beta) for ordinal
      split trans(\beta)\wedge irrefrelon(\beta,in)\wedge wellorder(\beta,in)
      expand trans(\beta) for trans
      expand irrefrelon(\beta,in) for irrefrelon
      expand wellorder(\beta,in) for wellorder
      split orderon(\beta,in)\wedge\forall^T\phi[1](\exists z(in(z,\beta)\wedge\phi(z))\to\exists a(minimum(\beta,in,\phi,a)))
      expand orderon(\beta,in) for orderon
      split transrelon(\beta,in)\wedge antisymrelon(\beta,in)
      deny \neg(subset(\alpha,\beta)\vee subset(\beta,\alpha)) {
        apply invoke rightward neg_or for \phi:lambda.subset(\alpha,\beta),\psi:lambda.subset(\beta,\alpha)
        split \neg(subset(\alpha,\beta))\wedge\neg(subset(\beta,\alpha))
        apply invoke rightward neg_subset for x:\alpha,y:\beta
        apply invoke \forall^T\phi[1](\exists z(in(z,\alpha)\wedge\phi(z))\to\exists\gamma(minimum(\alpha,in,\phi,\gamma))) for \phi:lambda z.notin(z,\beta)
        apply invoke rightward neg_subset for x:\beta,y:\alpha
        apply invoke \forall^T\phi[1](\exists z(in(z,\beta)\wedge\phi(z))\to\exists\delta(minimum(\beta,in,\phi,\delta))) for \phi:lambda z.notin(z,\alpha)
        some \gamma:\gamma such \exists\gamma(minimum(\alpha,in,lambda z.notin(z,\beta),\gamma)) {
          some \delta:\delta such \exists\delta(minimum(\beta,in,lambda z.notin(z,\alpha),\delta)) {
            expand minimum(\alpha,in,lambda z.notin(z,\beta),\gamma) for minimum
            split in(\gamma,\alpha)\wedge notin(\gamma,\beta)\wedge\forall x(in(x,\alpha)\wedge notin(x,\beta)\wedge neq(x,\gamma)\to in(\gamma,x))
            expand minimum(\beta,in,lambda z.notin(z,\alpha),\delta) for minimum
            split in(\delta,\beta)\wedge notin(\delta,\alpha)\wedge\forall x(in(x,\beta)\wedge notin(x,\alpha)\wedge neq(x,\delta)\to in(\delta,x))
            deny \neg(subset(\gamma,\delta)) {
              apply invoke rightward neg_subset for x:\gamma,y:\delta
              some \varepsilon:\varepsilon such \exists\varepsilon(in(\varepsilon,\gamma)\wedge notin(\varepsilon,\delta)) {
                split in(\varepsilon,\gamma)\wedge notin(\varepsilon,\delta)
                connect in(\varepsilon,\gamma)\wedge in(\gamma,\alpha)
                apply invoke \forall y\forall z(in(z,y)\wedge in(y,\alpha)\to in(z,\alpha)) for y:\gamma,z:\varepsilon
                deny equal(\varepsilon,\gamma) {
                  substitute in(\varepsilon,\gamma) for \varepsilon:\gamma
                  apply invoke \forall x(in(x,\alpha)\to notin(x,x)) for x:\gamma
                  contradict in(\gamma,\gamma)
                }
                apply \forall x(in(x,\alpha)\to notin(x,x)) for x:\varepsilon
                connect antisymrelon(\alpha,in)\wedge minimum(\alpha,in,lambda z.notin(z,\beta),\gamma)
                apply invoke minimum_implies_minimal for X:\alpha,\psi:in,\phi:lambda z.notin(z,\beta),a:\gamma
                expand minimal(\alpha,in,lambda z.notin(z,\beta),\gamma) for minimal
                split in(\gamma,\alpha)\wedge notin(\gamma,\beta)\wedge\forall x(in(x,\alpha)\wedge notin(x,\beta)\wedge neq(x,\gamma)\to notin(x,\gamma))
                deny notin(\varepsilon,\beta) {
                  connect in(\varepsilon,\alpha)\wedge notin(\varepsilon,\beta)\wedge neq(\varepsilon,\gamma)
                  apply invoke \forall x(in(x,\alpha)\wedge notin(x,\beta)\wedge neq(x,\gamma)\to notin(x,\gamma)) for x:\varepsilon
                  contradict in(\varepsilon,\gamma)
                }
                apply invoke wellorder_implies_linorder for X:\beta,\psi:in
                expand linorder(\beta,in) for linorder
                split orderon(\beta,in)\wedge\forall x\forall y(in(x,\beta)\wedge in(y,\beta)\to in(x,y)\vee equal(x,y)\vee in(y,x))
                connect in(\varepsilon,\beta)\wedge in(\delta,\beta)
                apply invoke \forall x\forall y(in(x,\beta)\wedge in(y,\beta)\to in(x,y)\vee equal(x,y)\vee in(y,x)) for x:\varepsilon,y:\delta
                divide in(\varepsilon,\delta)\vee equal(\varepsilon,\delta)\vee in(\delta,\varepsilon)
                  case in(\varepsilon,\delta) {
                    contradict in(\varepsilon,\delta)
                  }
                  case equal(\varepsilon,\delta) {
                    substitute in(\varepsilon,\alpha) for \varepsilon:\delta
                    contradict in(\delta,\alpha)
                  }
                  case in(\delta,\varepsilon) {
                    connect in(\delta,\varepsilon)\wedge in(\varepsilon,\alpha)
                    apply invoke \forall y\forall z(in(z,y)\wedge in(y,\alpha)\to in(z,\alpha)) for y:\varepsilon,z:\delta
                    contradict in(\delta,\alpha)
                  }
              }
            }
            deny \neg(subset(\delta,\gamma)) {
              apply invoke rightward neg_subset for x:\delta,y:\gamma
              some \varepsilon:\varepsilon such \exists\varepsilon(in(\varepsilon,\delta)\wedge notin(\varepsilon,\gamma)) {
                split in(\varepsilon,\delta)\wedge notin(\varepsilon,\gamma)
                connect in(\varepsilon,\delta)\wedge in(\delta,\beta)
                apply invoke \forall y\forall z(in(z,y)\wedge in(y,\beta)\to in(z,\beta)) for y:\delta,z:\varepsilon
                deny equal(\varepsilon,\delta) {
                  substitute in(\varepsilon,\delta) for \varepsilon:\delta
                  apply invoke \forall x(in(x,\beta)\to notin(x,x)) for x:\delta
                  contradict in(\delta,\delta)
                }
                apply \forall x(in(x,\beta)\to notin(x,x)) for x:\varepsilon
                connect antisymrelon(\beta,in)\wedge minimum(\beta,in,lambda z.notin(z,\alpha),\delta)
                apply invoke minimum_implies_minimal for X:\beta,\psi:in,\phi:lambda z.notin(z,\alpha),a:\delta
                expand minimal(\beta,in,lambda z.notin(z,\alpha),\delta) for minimal
                split in(\delta,\beta)\wedge notin(\delta,\alpha)\wedge\forall x(in(x,\beta)\wedge notin(x,\alpha)\wedge neq(x,\delta)\to notin(x,\delta))
                deny notin(\varepsilon,\alpha) {
                  connect in(\varepsilon,\beta)\wedge notin(\varepsilon,\alpha)\wedge neq(\varepsilon,\delta)
                  apply invoke \forall x(in(x,\beta)\wedge notin(x,\alpha)\wedge neq(x,\delta)\to notin(x,\delta)) for x:\varepsilon
                  contradict in(\varepsilon,\delta)
                }
                apply invoke wellorder_implies_linorder for X:\alpha,\psi:in
                expand linorder(\alpha,in) for linorder
                split orderon(\alpha,in)\wedge\forall x\forall y(in(x,\alpha)\wedge in(y,\alpha)\to in(x,y)\vee equal(x,y)\vee in(y,x))
                connect in(\varepsilon,\alpha)\wedge in(\gamma,\alpha)
                apply invoke \forall x\forall y(in(x,\alpha)\wedge in(y,\alpha)\to in(x,y)\vee equal(x,y)\vee in(y,x)) for x:\varepsilon,y:\gamma
                divide in(\varepsilon,\gamma)\vee equal(\varepsilon,\gamma)\vee in(\gamma,\varepsilon)
                  case in(\varepsilon,\gamma) {
                    contradict in(\varepsilon,\gamma)
                  }
                  case equal(\varepsilon,\gamma) {
                    substitute in(\varepsilon,\beta) for \varepsilon:\gamma
                    contradict in(\gamma,\beta)
                  }
                  case in(\gamma,\varepsilon) {
                    connect in(\gamma,\varepsilon)\wedge in(\varepsilon,\beta)
                    apply invoke \forall y\forall z(in(z,y)\wedge in(y,\beta)\to in(z,\beta)) for y:\varepsilon,z:\gamma
                    contradict in(\gamma,\beta)
                  }
              }
            }
            connect subset(\gamma,\delta)\wedge subset(\delta,\gamma)
            apply invoke rightward subset_antisymmetry for x:\gamma,y:\delta
            substitute in(\gamma,\alpha) for \gamma:\delta
            contradict in(\delta,\alpha)
          }
        }
      }
    }
  }
}

theorem ordinals_trichotomy_subset \forall\alpha\forall\beta(ordinal(\alpha)\wedge ordinal(\beta)\to subsetneq(\alpha,\beta)\vee equal(\alpha,\beta)\vee subsetneq(\beta,\alpha)) {
  any \alpha,\beta {
    assume ordinal(\alpha)\wedge ordinal(\beta) {
      apply invoke ordinals_comparable_subset for \alpha:\alpha,\beta:\beta
      divide subset(\alpha,\beta)\vee subset(\beta,\alpha)
        case subset(\alpha,\beta) {
          apply invoke rightward subset_subsetneq for x:\alpha,y:\beta
          pad subsetneq(\alpha,\beta)\vee equal(\alpha,\beta) conclude subsetneq(\alpha,\beta)\vee equal(\alpha,\beta)\vee subsetneq(\beta,\alpha)
        }
        case subset(\beta,\alpha) {
          apply invoke rightward subset_subsetneq for x:\beta,y:\alpha
          pad subsetneq(\beta,\alpha)\vee equal(\alpha,\beta) conclude subsetneq(\alpha,\beta)\vee equal(\alpha,\beta)\vee subsetneq(\beta,\alpha)
        }
    }
  }
}

theorem ordinals_trichotomy_in \forall\alpha\forall\beta(ordinal(\alpha)\wedge ordinal(\beta)\to in(\alpha,\beta)\vee equal(\alpha,\beta)\vee in(\beta,\alpha)) {
  any \alpha,\beta {
    assume ordinal(\alpha)\wedge ordinal(\beta) {
      apply invoke ordinals_trichotomy_subset for \alpha:\alpha,\beta:\beta
      divide subsetneq(\alpha,\beta)\vee equal(\alpha,\beta)\vee subsetneq(\beta,\alpha)
        case subsetneq(\alpha,\beta) {
          apply invoke ordinal_in_iff_subsetneq for \alpha:\alpha,\beta:\beta
          invoke leftward in(\alpha,\beta)\leftrightarrow subsetneq(\alpha,\beta)
          pad in(\alpha,\beta) conclude in(\alpha,\beta)\vee equal(\alpha,\beta)\vee in(\beta,\alpha)
        }
        case equal(\alpha,\beta) {
          pad equal(\alpha,\beta) conclude in(\alpha,\beta)\vee equal(\alpha,\beta)\vee in(\beta,\alpha)
        }
        case subsetneq(\beta,\alpha) {
          apply invoke ordinal_in_iff_subsetneq for \alpha:\beta,\beta:\alpha
          invoke leftward in(\beta,\alpha)\leftrightarrow subsetneq(\beta,\alpha)
          pad in(\beta,\alpha) conclude in(\alpha,\beta)\vee equal(\alpha,\beta)\vee in(\beta,\alpha)
        }
    }
  }
}
