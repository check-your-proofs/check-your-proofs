theorem order_relsep_subset \forall X\forall^T\phi[2]\forall Y(order(relsep(X,\phi))\wedge subset(Y,X)\to order(relsep(Y,\phi))) {
  any X, template \phi[2], Y {
    assume order(relsep(X,\phi))\wedge subset(Y,X) {
      split order(relsep(X,\phi))\wedge subset(Y,X)
      expand order(relsep(X,\phi)) for order
      split transrel(relsep(X,\phi))\wedge antisymrel(relsep(X,\phi))
      connect transrel(relsep(X,\phi))\wedge subset(Y,X)
      apply invoke transrel_relsep_subset for X:X,\phi:\phi,Y:Y
      connect antisymrel(relsep(X,\phi))\wedge subset(Y,X)
      apply invoke antisymrel_relsep_subset for X:X,\phi:\phi,Y:Y
      connect transrel(relsep(Y,\phi))\wedge  antisymrel(relsep(Y,\phi))
      fold for order conclude order(relsep(Y,\phi))
    }
  }
}

