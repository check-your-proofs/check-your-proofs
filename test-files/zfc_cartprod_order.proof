theorem antisymrelon_relsep_subset \forall X\forall^T\phi[2]\forall Y(antisymrelon(X,relsep(X,\phi))\wedge subset(Y,X)\to antisymrelon(Y,relsep(Y,\phi))) {
  any X, template \phi[2], Y {
    assume antisymrelon(X,relsep(X,\phi))\wedge subset(Y,X) {
      split antisymrelon(X,relsep(X,\phi))\wedge subset(Y,X)
      apply invoke res_of_antisymrelon_is_antisymrelon for R:relsep(X,\phi),X:X,Y:Y
      apply invoke relsep_res for X:X,\phi:\phi,Y:Y
      substitute antisymrelon(Y,res(relsep(X,\phi),Y)) for res(relsep(X,\phi),Y):relsep(Y,\phi)
