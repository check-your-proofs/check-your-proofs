    assume orderon(X,relsep(X,\phi))\wedge subset(Y,X) {
      split orderon(X,relsep(X,\phi))\wedge subset(Y,X)
      apply invoke res_of_orderon_is_orderon for R:relsep(X,\phi),X:X,Y:Y
      apply invoke relsep_res for X:X,\phi:\phi,Y:Y
      substitute orderon(Y,res(relsep(X,\phi),Y)) for res(relsep(X,\phi),Y):relsep(Y,\phi)
