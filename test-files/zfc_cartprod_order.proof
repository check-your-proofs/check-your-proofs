theorem emptyset_is_transrel transrel(emptyset) {
  any x,y,z {
    assume in(op(x,y),emptyset)\wedge in(op(y,z),emptyset) {
      split in(op(x,y),emptyset)\wedge in(op(y,z),emptyset)
      apply emptyset_existence for y:op(x,y)
      contradict in(op(x,y),emptyset)
      explode in(op(x,z),emptyset)
    }
  }
  fold for transrel conclude transrel(emptyset)
}

theorem emptyset_is_transrelon_emptyset transrelon(emptyset,emptyset) {
  assert emptyset_is_relon_emptyset
  assert emptyset_is_transrel
  connect relon(emptyset,emptyset)\wedge transrel(emptyset)
  fold for transrelon conclude transrelon(emptyset,emptyset)
}

theorem emptyset_is_antisymrel antisymrel(emptyset) {
  any x,y {
    assume in(op(x,y),emptyset)\wedge in(op(y,x),emptyset) {
      split 1 in(op(x,y),emptyset)\wedge in(op(y,x),emptyset)
      apply emptyset_existence for y:op(x,y)
      contradict in(op(x,y),emptyset)
      explode equal(x,y)
    }
  }
  fold for antisymrel conclude antisymrel(emptyset)
}

theorem emptyset_is_antisymrelon_emptyset antisymrelon(emptyset,emptyset) {
  assert emptyset_is_relon_emptyset
  assert emptyset_is_antisymrel
  connect relon(emptyset,emptyset)\wedge antisymrel(emptyset)
  fold for antisymrelon conclude antisymrelon(emptyset,emptyset)
}

theorem emptyset_is_order order(emptyset) {
  assert emptyset_is_transrel
  assert emptyset_is_antisymrel
  connect transrel(emptyset)\wedge antisymrel(emptyset)
  fold for order conclude order(emptyset)
}

theorem emptyset_is_orderon_emptyset orderon(emptyset,emptyset) {
  assert emptyset_is_relon_emptyset
  assert emptyset_is_order
  connect relon(emptyset,emptyset)\wedge order(emptyset)
  fold for orderon conclude orderon(emptyset,emptyset)
}

theorem emptyset_is_irrefrel irrefrel(emptyset) {
  any x {
    apply emptyset_existence for y:op(x,x)
  }
  fold for irrefrel conclude irrefrel(emptyset)
}

theorem emptyset_is_irrefrelon_emptyset irrefrelon(emptyset,emptyset) {
  assert emptyset_is_relon_emptyset
  assert emptyset_is_irrefrel
  connect relon(emptyset,emptyset)\wedge irrefrel(emptyset)
  fold for irrefrelon conclude irrefrelon(emptyset,emptyset)
}

theorem emptyset_is_wellorder_emptyset wellorder(emptyset,emptyset) {
  assert emptyset_is_orderon_emptyset
  any A {
    assume subset(A,emptyset)\wedge neq(A,emptyset) {
      split subset(A,emptyset)\wedge neq(A,emptyset)
      apply invoke emptyset_subset_cor1 for x:A
      contradict equal(A,emptyset)
      explode \exists a(minimum(emptyset,emptyset,A,a))
    }
  }
  connect orderon(emptyset,emptyset)\wedge\forall A(subset(A,emptyset)\wedge neq(A,emptyset)\to\exists a(minimum(emptyset,emptyset,A,a)))
  fold for wellorder conclude wellorder(emptyset,emptyset)
}
